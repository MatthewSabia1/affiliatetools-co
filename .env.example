# OpenRouter — content generation (see scripts/generate-content.mjs)
# Get keys at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxx

# Primary model — any OpenRouter-supported chat model works.
# Free-tier Gemma options: google/gemma-3-27b-it:free, google/gemma-4-31b-it:free
OPENROUTER_MODEL=google/gemma-3-27b-it:free

# Fallback model — used if the primary errors (model not found, rate limited, etc).
OPENROUTER_FALLBACK_MODEL=google/gemma-3-27b-it:free

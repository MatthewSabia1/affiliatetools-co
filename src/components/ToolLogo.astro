---
/**
 * ToolLogo.astro — Renders a competitor's logo from YAML data.
 * Handles raster + SVG logos and optional surface styling for better contrast.
 */
import { getCompetitor } from '@/lib/competitors';
import type { CompetitorSlug } from '@/lib/constants';

export interface Props {
  slug: CompetitorSlug;
  size?: 'sm' | 'md' | 'lg' | 'xl';
  showName?: boolean;
  surface?: 'auto' | 'none' | 'neutral' | 'dark';
  mode?: 'full' | 'mark';
}

const {
  slug,
  size = 'md',
  showName = false,
  surface = 'auto',
  mode = 'full',
} = Astro.props;

const competitor = await getCompetitor(slug);
const { name, logo } = competitor.data;

const SIZES: Record<NonNullable<Props['size']>, number> = {
  sm: 20,
  md: 28,
  lg: 40,
  xl: 64,
};

const px = SIZES[size];
const isMarkMode = mode === 'mark';
const width = isMarkMode ? px : (logo.width ?? px);
const height = isMarkMode ? px : (logo.height ?? px);
// Preserve intrinsic aspect ratio but scale the displayed height to `px`.
const aspect = width && height ? width / height : 1;
const displayH = px;
const displayW = Math.round(displayH * aspect);

const logoPath = isMarkMode
  ? `/logos/marks/${slug}.svg`
  : (logo.path.startsWith('/') ? logo.path : `/${logo.path}`);
const resolvedSurface =
  surface === 'auto' ? (logo.surface ?? 'transparent') : surface;
---

<span
  class:list={[
    'tool-logo',
    `size-${size}`,
    `surface-${resolvedSurface}`,
    `mode-${mode}`,
    logo.invertInLight ? 'invert-in-light' : null,
  ]}
>
  <span class="tool-logo__mark">
    <img
      src={logoPath}
      alt={`${name} logo`}
      width={displayW}
      height={displayH}
      loading="eager"
      decoding="async"
    />
  </span>
  {showName && <span class="tool-logo__name">{name}</span>}
</span>

<style>
  .tool-logo {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    line-height: 1;
    vertical-align: middle;
  }
  .tool-logo__mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 auto;
  }
  .tool-logo img {
    display: block;
    object-fit: contain;
    max-height: 100%;
  }
  .tool-logo__name {
    font-family: var(--font-sans);
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--color-type);
  }

  .size-sm .tool-logo__name { font-size: 0.9rem; }
  .size-md .tool-logo__name { font-size: 1rem; }
  .size-lg .tool-logo__name { font-size: 1.15rem; }
  .size-xl .tool-logo__name { font-size: 1.4rem; }

  .surface-neutral .tool-logo__mark,
  .surface-dark .tool-logo__mark {
    border-radius: 999px;
    padding: 0.42rem 0.7rem;
    border: 1px solid var(--color-line);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.6);
  }
  .surface-neutral .tool-logo__mark {
    background: linear-gradient(180deg, #ffffff 0%, #f2f5f9 100%);
  }
  .surface-dark .tool-logo__mark {
    background: linear-gradient(180deg, #142238 0%, #0d1727 100%);
    border-color: color-mix(in oklch, #0d1727 72%, white);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.08),
      0 10px 24px rgba(10, 18, 31, 0.14);
  }
  .size-sm.surface-neutral .tool-logo__mark,
  .size-sm.surface-dark .tool-logo__mark {
    padding: 0.32rem 0.55rem;
  }
  .size-lg.surface-neutral .tool-logo__mark,
  .size-lg.surface-dark .tool-logo__mark {
    padding: 0.5rem 0.82rem;
  }
  .size-xl.surface-neutral .tool-logo__mark,
  .size-xl.surface-dark .tool-logo__mark {
    padding: 0.65rem 1rem;
  }
  .surface-none .tool-logo__mark {
    padding: 0;
    border: 0;
    box-shadow: none;
    background: transparent;
    border-radius: 0;
  }
  .mode-mark {
    gap: 0.62rem;
  }
  .mode-mark .tool-logo__mark {
    border-radius: 12px;
    flex: 0 0 auto;
  }
  .mode-mark img {
    max-width: 100%;
    width: auto;
    height: auto;
  }
  .mode-mark .tool-logo__name {
    font-weight: 720;
    letter-spacing: -0.022em;
  }

  /* Site is dark-first; invert is a hint for logos that were authored
     for light backgrounds. Flip to a near-white rendering. */
  @media (prefers-color-scheme: dark) {
    .invert-in-light img { filter: none; }
  }
  .invert-in-light img {
    filter: brightness(0) invert(1);
  }
</style>

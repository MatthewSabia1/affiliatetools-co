---
/**
 * ScoringMethodology.astro — Scroll-triggered, data-rich showcase of
 * AffiliateTools.co's 8-dimension scoring rubric. Designed as an editorial
 * "feature spread" that pairs the light SaaS canvas with dark navy data panels.
 *
 * Zero JS frameworks. Pure Astro + CSS + a tiny IntersectionObserver script
 * for scroll-triggered bar fills and counters.
 */

import { getCompetitorsInDisplayOrder } from '@/lib/competitors';

const competitors = await getCompetitorsInDisplayOrder();

type AxisKey =
  | 'coverage'
  | 'dataFreshness'
  | 'price'
  | 'ux'
  | 'landingPages'
  | 'offers'
  | 'affiliateFocus'
  | 'search';

function getAxisScore(
  scores: (typeof competitors)[number]['data']['scores'],
  axis: AxisKey,
): number {
  return scores[axis];
}

// Derive top 3 scorers per dimension from actual yaml data (no fabricated numbers)
function topThreeOn(axis: AxisKey) {
  return competitors
    .map((c) => ({
      name: c.data.name,
      slug: c.data.slug,
      score: getAxisScore(c.data.scores, axis),
    }))
    .sort((a, b) => b.score - a.score)
    .slice(0, 3);
}

interface Dimension {
  key: AxisKey;
  number: string;
  name: string;
  measure: string;
  /** Marketing-grade inline SVG — no icon library needed */
  icon: string;
}

const dimensions: Dimension[] = [
  {
    key: 'coverage',
    number: '01',
    name: 'Coverage',
    measure: 'Platform breadth, geo reach, crawl recency, claimed DB size.',
    icon: '<circle cx="12" cy="12" r="9"/><path d="M3 12h18"/><path d="M12 3a13.5 13.5 0 0 1 0 18"/><path d="M12 3a13.5 13.5 0 0 0 0 18"/>',
  },
  {
    key: 'dataFreshness',
    number: '02',
    name: 'Data freshness',
    measure: 'Crawl cadence, dead-creative flags, dedupe across runs.',
    icon: '<path d="M3 12a9 9 0 1 0 3-6.7"/><path d="M3 3v5h5"/><path d="M12 8v4l3 2"/>',
  },
  {
    key: 'price',
    number: '03',
    name: 'Price',
    measure: 'Value per dollar at the tier you would actually run on.',
    icon: '<path d="M12 3v18"/><path d="M17 7H9.5a3 3 0 1 0 0 6h5a3 3 0 1 1 0 6H6"/>',
  },
  {
    key: 'ux',
    number: '04',
    name: 'UX',
    measure: 'Interface quality, filter flow, exports, learning curve.',
    icon: '<rect x="3" y="4" width="18" height="16" rx="2"/><path d="M3 9h18"/><path d="M7 14h4"/><path d="M7 17h7"/>',
  },
  {
    key: 'landingPages',
    number: '05',
    name: 'Landing pages',
    measure: 'URL capture, screenshots, full HTML/CSS archives.',
    icon: '<rect x="3" y="4" width="18" height="16" rx="2"/><path d="M3 8h18"/><path d="M7 13h6"/><path d="M7 16h10"/><path d="M16 13l3 3-3 3"/>',
  },
  {
    key: 'offers',
    number: '06',
    name: 'Offers',
    measure: 'Offer intelligence, network breakdown, top-by-days-running.',
    icon: '<path d="M20.6 13.4 13.4 20.6a2 2 0 0 1-2.8 0L3 13V3h10l7.6 7.6a2 2 0 0 1 0 2.8Z"/><circle cx="7.5" cy="7.5" r="1.5"/>',
  },
  {
    key: 'affiliateFocus',
    number: '07',
    name: 'Affiliate focus',
    measure: 'Network classification (ClickBank, Digistore, BuyGoods, MaxWeb).',
    icon: '<path d="M8 13a5 5 0 0 1 7-7l1 1a5 5 0 0 1-7 7"/><path d="M16 11a5 5 0 0 1-7 7l-1-1a5 5 0 0 1 7-7"/>',
  },
  {
    key: 'search',
    number: '08',
    name: 'Search',
    measure: 'Boolean operators, saved searches, filter sophistication.',
    icon: '<circle cx="11" cy="11" r="7"/><path d="m20 20-4.3-4.3"/>',
  },
];

// Weight per listicle intent (from methodology.astro) — normalized 0-100
type WeightLevel = 1 | 2 | 3 | 4; // low / medium / high / critical
interface Listicle {
  slug: string;
  title: string;
  intent: string;
  weights: Record<AxisKey, WeightLevel>;
}

const listicles: Listicle[] = [
  {
    slug: 'best-overall',
    title: 'Best overall',
    intent: 'Head-term buyers · balanced weighting',
    weights: {
      coverage: 3, dataFreshness: 3, price: 3, ux: 3,
      landingPages: 3, offers: 3, affiliateFocus: 3, search: 3,
    },
  },
  {
    slug: 'affiliate',
    title: 'Best for affiliates',
    intent: 'CPA operators · network-aware research',
    weights: {
      coverage: 2, dataFreshness: 3, price: 2, ux: 2,
      landingPages: 4, offers: 4, affiliateFocus: 4, search: 2,
    },
  },
  {
    slug: 'facebook',
    title: 'Best for Facebook / Meta',
    intent: 'Meta-only operators · LP + offer weighted',
    weights: {
      coverage: 2, dataFreshness: 3, price: 2, ux: 3,
      landingPages: 4, offers: 3, affiliateFocus: 3, search: 3,
    },
  },
  {
    slug: 'free',
    title: 'Best free',
    intent: 'No-budget evaluators · price dominates',
    weights: {
      coverage: 2, dataFreshness: 2, price: 4, ux: 2,
      landingPages: 1, offers: 1, affiliateFocus: 2, search: 2,
    },
  },
  {
    slug: 'clickbank',
    title: 'Best for ClickBank / Digistore',
    intent: 'Network-specific · classification is king',
    weights: {
      coverage: 2, dataFreshness: 3, price: 2, ux: 2,
      landingPages: 3, offers: 4, affiliateFocus: 4, search: 2,
    },
  },
];

const WEIGHT_LABELS: Record<WeightLevel, string> = {
  1: 'Low',
  2: 'Medium',
  3: 'High',
  4: 'Critical',
};

const testSteps = [
  {
    num: '01',
    title: 'Signup',
    body: 'We create a real account, pay for the lowest tier when no free option exists, and work through the onboarding flow firsthand.',
  },
  {
    num: '02',
    title: 'Feature walkthrough',
    body: 'Every claim on the marketing page gets exercised. If the tool says it does X, we try X and document what actually happens.',
  },
  {
    num: '03',
    title: 'Search stress test',
    body: 'The same query set runs across every tool — a ClickBank health offer, a Digistore BizOpp ad, a viral TikTok dropship product.',
  },
  {
    num: '04',
    title: 'Landing page capture',
    body: 'We test whether LPs get captured at all, and in what format — URL only, screenshot, or full HTML + asset archive.',
  },
  {
    num: '05',
    title: 'Export + integrations',
    body: 'Export formats, design-tool integrations, API access, and team-seat behavior are all poked. Broken exports are flagged.',
  },
  {
    num: '06',
    title: 'Pricing cross-check',
    body: 'Prices get re-verified against the tool\u2019s live pricing page on publish day, cited with a date. No stale MSRPs.',
  },
];

const refusals = [
  'No paid placements. A tool cannot buy a ranking or buy its way onto a listicle.',
  'No fabricated user quotes or testimonials. If no real quote exists, no quote appears.',
  'No fabricated star ratings — every score is AffiliateTools.co\u2019s editorial opinion, labeled as such.',
  'No "10x better" superlatives. Specific claims or nothing.',
  'No reviews of tools we haven\u2019t actually used. Every review is hands-on, not marketing-copy rehash.',
];
---

<section class="sm-wrap" aria-labelledby="scoring-method-heading">
  <!-- =========================================================
       1. INTRO BAND — dark navy, editorial headline
       ========================================================= -->
  <div class="sm-intro">
    <div class="sm-intro__grid container-wide">
      <div class="sm-intro__copy">
        <p class="sm-eyebrow">
          <span class="sm-eyebrow__dot" aria-hidden="true"></span>
          Methodology · How we score
        </p>
        <h2 id="scoring-method-heading" class="sm-intro__headline">
          Eight dimensions. <em>Zero shortcuts.</em>
        </h2>
        <p class="sm-intro__sub">
          Every ad spy tool we cover is graded 1&ndash;10 on the same rubric by operators who
          run campaigns for a living. No scraped G2 averages. No affiliate-commission-weighted
          math. Just hands-on testing, dated pricing, and disclosed bias.
        </p>
        <div class="sm-intro__stats" role="list">
          <div class="sm-stat" role="listitem">
            <span class="sm-stat__num mono">8</span>
            <span class="sm-stat__lbl">Weighted dimensions</span>
          </div>
          <div class="sm-stat" role="listitem">
            <span class="sm-stat__num mono">7</span>
            <span class="sm-stat__lbl">Tools under review</span>
          </div>
          <div class="sm-stat" role="listitem">
            <span class="sm-stat__num mono">Q/Q</span>
            <span class="sm-stat__lbl">Pricing re-verified</span>
          </div>
          <div class="sm-stat" role="listitem">
            <span class="sm-stat__num mono">0</span>
            <span class="sm-stat__lbl">Paid placements</span>
          </div>
        </div>
      </div>
      <!-- Diagonal accent panel -->
      <div class="sm-intro__panel" aria-hidden="true">
        <div class="sm-intro__panel-label mono">RUBRIC.v1</div>
        <div class="sm-intro__panel-grid">
          {dimensions.map((d) => (
            <div class="sm-intro__panel-cell">
              <span class="mono sm-intro__panel-num">{d.number}</span>
              <span class="sm-intro__panel-nm">{d.name}</span>
            </div>
          ))}
        </div>
        <div class="sm-intro__panel-foot mono">
          <span>SCORE · 1 &mdash; 10</span>
          <span>UPDATED · APR 2026</span>
        </div>
      </div>
    </div>
  </div>

  <!-- =========================================================
       2. THE 8 DIMENSIONS — responsive grid
       ========================================================= -->
  <div class="container-wide sm-section">
    <div class="sm-section-head">
      <p class="label-mono sm-kicker">The rubric</p>
      <h3>What we actually measure.</h3>
      <p class="sm-section-head__sub">
        Eight independent axes. Each scored from firsthand use of the product &mdash; not from
        reading a comparison table somewhere else.
      </p>
    </div>

    <div class="sm-dim-grid sm-reveal-root">
      {dimensions.map((dim, idx) => {
        const top = topThreeOn(dim.key);
        return (
          <article
            class="sm-dim sm-reveal"
            style={`--i:${idx}`}
            data-dim={dim.key}
            aria-labelledby={`dim-${dim.key}`}
          >
            <header class="sm-dim__head">
              <div class="sm-dim__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" set:html={dim.icon} />
              </div>
              <span class="sm-dim__num mono">{dim.number}</span>
            </header>
            <h4 id={`dim-${dim.key}`} class="sm-dim__name">{dim.name}</h4>
            <p class="sm-dim__measure">{dim.measure}</p>

            <div class="sm-dim__scale" aria-hidden="true">
              {Array.from({ length: 10 }).map((_, i) => (
                <span class="sm-dim__tick" style={`--t:${i}`} />
              ))}
            </div>

            <div class="sm-dim__leader">
              <span class="label-mono sm-dim__leader-lbl">Top scorers</span>
              <ul class="sm-dim__leader-list">
                {top.map((t, i) => (
                  <li class:list={['sm-dim__pill', i === 0 ? 'is-first' : null]}>
                    <span class="mono sm-dim__pill-score">{t.score}</span>
                    <span class="sm-dim__pill-name">{t.name}</span>
                  </li>
                ))}
              </ul>
            </div>
          </article>
        );
      })}
    </div>
  </div>

  <!-- =========================================================
       3. LISTICLE WEIGHTING — the same 8, weighted differently
       ========================================================= -->
  <div class="sm-weights-band">
    <div class="container-wide sm-weights">
      <div class="sm-weights__head">
        <p class="label-mono sm-kicker sm-kicker--dark">Weighting</p>
        <h3>Same rubric. <em>Different jobs.</em></h3>
        <p class="sm-weights__sub">
          The same eight axes get re-weighted by buyer intent. Here&rsquo;s how the weighting
          shifts across five of our flagship listicles &mdash; critical axes fill darkest, low-weight
          axes stay muted.
        </p>
      </div>

      <div class="sm-weights__table sm-reveal-root" role="table" aria-label="How different listicles weight the eight dimensions">
        <div class="sm-weights__row sm-weights__row--head" role="row">
          <div class="sm-weights__intent" role="columnheader">Listicle intent</div>
          {dimensions.map((d) => (
            <div class="sm-weights__col-head" role="columnheader" title={d.name}>
              <span class="mono">{d.number}</span>
              <span class="sm-weights__col-name">{d.name}</span>
            </div>
          ))}
        </div>

        {listicles.map((l, rowIdx) => (
          <div class="sm-weights__row sm-reveal" style={`--i:${rowIdx}`} role="row">
            <div class="sm-weights__intent" role="rowheader">
              <span class="sm-weights__intent-title">{l.title}</span>
              <span class="sm-weights__intent-sub">{l.intent}</span>
            </div>
            {dimensions.map((d) => {
              const w = l.weights[d.key];
              return (
                <div class="sm-weights__cell" role="cell" title={`${d.name}: ${WEIGHT_LABELS[w]}`}>
                  <div class={`sm-weights__bar sm-weights__bar--w${w}`}>
                    <span class="sm-weights__bar-fill" style={`--w:${w}`}></span>
                  </div>
                  <span class="sm-weights__cell-lbl mono">{WEIGHT_LABELS[w].slice(0, 3).toUpperCase()}</span>
                </div>
              );
            })}
          </div>
        ))}
      </div>

      <div class="sm-weights__legend" aria-hidden="true">
        <span class="sm-weights__legend-title mono">WEIGHT</span>
        {([1, 2, 3, 4] as WeightLevel[]).map((w) => (
          <span class="sm-weights__legend-item">
            <span class={`sm-weights__legend-swatch sm-weights__bar--w${w}`}></span>
            {WEIGHT_LABELS[w]}
          </span>
        ))}
      </div>
    </div>
  </div>

  <!-- =========================================================
       4. HANDS-ON TEST PROCESS — numbered steps
       ========================================================= -->
  <div class="container-wide sm-section">
    <div class="sm-section-head">
      <p class="label-mono sm-kicker">The test bench</p>
      <h3>What we do &mdash; on every tool, every review.</h3>
      <p class="sm-section-head__sub">
        Six steps. No exceptions. This is the part that scraper-review sites skip.
      </p>
    </div>

    <ol class="sm-steps sm-reveal-root" role="list">
      {testSteps.map((s, i) => (
        <li class="sm-step sm-reveal" style={`--i:${i}`}>
          <div class="sm-step__chrome" aria-hidden="true">
            <span class="sm-step__dot sm-step__dot--red"></span>
            <span class="sm-step__dot sm-step__dot--amber"></span>
            <span class="sm-step__dot sm-step__dot--green"></span>
            <span class="sm-step__chrome-lbl mono">step-{s.num}.log</span>
          </div>
          <div class="sm-step__body">
            <span class="sm-step__num mono">{s.num}</span>
            <h4 class="sm-step__title">{s.title}</h4>
            <p class="sm-step__text">{s.body}</p>
          </div>
          <div class="sm-step__ill" aria-hidden="true">
            {s.num === '01' && (
              <div class="ill-signup">
                <div class="ill-field"><span class="ill-field-lbl mono">EMAIL</span><span class="ill-field-val">hello@adrecon.io</span></div>
                <div class="ill-field"><span class="ill-field-lbl mono">CARD</span><span class="ill-field-val">•••• 4242</span></div>
                <div class="ill-btn mono">SUBSCRIBE · $149/mo</div>
              </div>
            )}
            {s.num === '02' && (
              <div class="ill-feat">
                <div class="ill-row"><span class="ill-check">✓</span><span>Boolean search</span></div>
                <div class="ill-row"><span class="ill-check">✓</span><span>Export to CSV</span></div>
                <div class="ill-row"><span class="ill-x">✗</span><span>Dead creative flag</span></div>
                <div class="ill-row"><span class="ill-check">✓</span><span>Saved folders</span></div>
              </div>
            )}
            {s.num === '03' && (
              <div class="ill-search">
                <div class="ill-query mono">q: clickbank OR digistore "30 day"</div>
                <div class="ill-bars">
                  <div class="ill-bar" style="--h:78%"></div>
                  <div class="ill-bar" style="--h:54%"></div>
                  <div class="ill-bar" style="--h:92%"></div>
                  <div class="ill-bar" style="--h:42%"></div>
                  <div class="ill-bar" style="--h:68%"></div>
                </div>
              </div>
            )}
            {s.num === '04' && (
              <div class="ill-lp">
                <div class="ill-lp-win"></div>
                <div class="ill-lp-zip mono">archive.zip<br/><span>HTML + CSS + 14 assets</span></div>
              </div>
            )}
            {s.num === '05' && (
              <div class="ill-api">
                <div class="ill-code mono">
                  <span class="c-mute">$</span> curl api/export<br/>
                  <span class="c-ok">200 OK</span> · 1,248 rows<br/>
                  <span class="c-mute">→</span> export.csv
                </div>
              </div>
            )}
            {s.num === '06' && (
              <div class="ill-price">
                <div class="ill-price-row">
                  <span class="ill-price-lbl">Site pricing page</span>
                  <span class="ill-price-val mono">$149.00</span>
                </div>
                <div class="ill-price-row is-match">
                  <span class="ill-price-lbl">Our cited price</span>
                  <span class="ill-price-val mono">$149.00 <span class="c-ok">✓</span></span>
                </div>
                <div class="ill-price-date mono">verified · Apr 17, 2026</div>
              </div>
            )}
          </div>
        </li>
      ))}
    </ol>
  </div>

  <!-- =========================================================
       5. WHAT WE REFUSE — anti-list
       ========================================================= -->
  <div class="container-wide sm-section">
    <div class="sm-refuse">
      <div class="sm-refuse__left">
        <p class="label-mono sm-kicker">What we refuse</p>
        <h3>The things we will <em>not</em> do.</h3>
        <p class="sm-refuse__sub">
          This list is short, specific, and will stay that way. If you find us breaking any of
          these, email <a href="mailto:hello@affiliatetools.co">hello@affiliatetools.co</a> and
          we&rsquo;ll fix it within 72 hours.
        </p>
      </div>
      <ul class="sm-refuse__list sm-reveal-root" role="list">
        {refusals.map((r, i) => (
          <li class="sm-refuse__item sm-reveal" style={`--i:${i}`}>
            <span class="sm-refuse__mark" aria-hidden="true">
              <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="5" x2="19" y2="19" />
                <line x1="19" y1="5" x2="5" y2="19" />
              </svg>
            </span>
            <span class="sm-refuse__text">{r}</span>
          </li>
        ))}
      </ul>
    </div>
  </div>

  <!-- =========================================================
       6. CTA
       ========================================================= -->
  <div class="container-wide sm-cta-wrap">
    <a class="sm-cta" href="/methodology/">
      <span class="sm-cta__col">
        <span class="label-mono sm-cta__kicker">Keep reading</span>
        <span class="sm-cta__title">Read the full methodology</span>
      </span>
      <span class="sm-cta__arrow" aria-hidden="true">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="5" y1="12" x2="19" y2="12" />
          <polyline points="12 5 19 12 12 19" />
        </svg>
      </span>
    </a>
  </div>
</section>

<script is:inline>
  /* Scroll-triggered reveal: adds `.is-in` to any `.sm-reveal-root` when it
     enters the viewport, which unlocks the staggered CSS transitions below. */
  (function () {
    if (typeof window === 'undefined' || !('IntersectionObserver' in window)) return;
    var roots = document.querySelectorAll('.sm-reveal-root');
    if (!roots.length) return;
    var reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduced) {
      roots.forEach(function (r) { r.classList.add('is-in'); });
      return;
    }
    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (e) {
        if (e.isIntersecting) {
          e.target.classList.add('is-in');
          io.unobserve(e.target);
        }
      });
    }, { rootMargin: '-60px 0px', threshold: 0.08 });
    roots.forEach(function (r) { io.observe(r); });
  })();
</script>

<style>
  /* ---------- Shared tokens (light base + dark panel) ---------- */
  .sm-wrap {
    --sm-dark: #0a0f1a;
    --sm-dark-2: #0e1524;
    --sm-dark-3: #14213b;
    --sm-dark-line: rgba(255, 255, 255, 0.08);
    --sm-dark-line-2: rgba(255, 255, 255, 0.14);
    --sm-dark-type: rgba(255, 255, 255, 0.94);
    --sm-dark-type-dim: rgba(255, 255, 255, 0.66);
    --sm-dark-type-mute: rgba(255, 255, 255, 0.44);
    --sm-accent-on-dark: #c8d5ef;

    position: relative;
    display: block;
    margin: 4rem 0 3rem;
  }

  /* Common kickers */
  .sm-kicker {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-accent);
    letter-spacing: 0.14em;
    margin: 0 0 0.5rem;
  }
  .sm-kicker::before {
    content: '';
    width: 22px;
    height: 1px;
    background: var(--color-accent);
    display: inline-block;
  }
  .sm-kicker--dark { color: var(--sm-accent-on-dark); }
  .sm-kicker--dark::before { background: var(--sm-accent-on-dark); }

  .sm-section {
    padding: 4.5rem 1.5rem;
  }
  .sm-section-head {
    max-width: 52rem;
    margin: 0 auto 2.5rem;
    text-align: center;
  }
  .sm-section-head h3 {
    font-size: clamp(1.8rem, 3vw, 2.5rem);
    margin: 0.5rem 0 0.75rem;
    letter-spacing: -0.025em;
    line-height: 1.08;
  }
  .sm-section-head h3 em { font-style: normal; color: var(--color-accent); }
  .sm-section-head__sub {
    color: var(--color-type-mute);
    font-size: 1.0625rem;
    margin: 0;
  }

  /* ================================================================
     1. INTRO BAND — dark navy gradient, asymmetric grid
     ================================================================ */
  .sm-intro {
    background:
      radial-gradient(1200px 400px at 85% -10%, rgba(200, 213, 239, 0.08), transparent 60%),
      radial-gradient(900px 500px at 10% 110%, rgba(21, 101, 181, 0.25), transparent 55%),
      linear-gradient(180deg, #0e2c5f 0%, #0a1a3a 60%, #0a0f1a 100%);
    color: var(--sm-dark-type);
    padding: 4.5rem 1.5rem 5rem;
    position: relative;
    overflow: hidden;
    border-radius: 0;
  }
  .sm-intro::before {
    /* Thin editorial grid overlay */
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.04) 1px, transparent 1px);
    background-size: 72px 72px;
    opacity: 0.9;
    pointer-events: none;
    mask-image: radial-gradient(closest-side at 50% 50%, #000 55%, transparent 95%);
  }
  .sm-intro__grid {
    display: grid;
    grid-template-columns: 1.25fr 1fr;
    gap: 3.5rem;
    align-items: center;
    position: relative;
  }
  @media (max-width: 980px) {
    .sm-intro__grid { grid-template-columns: 1fr; gap: 2.5rem; }
  }

  .sm-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--sm-accent-on-dark);
    margin: 0 0 1.25rem;
    padding: 0.35rem 0.75rem;
    border: 1px solid var(--sm-dark-line-2);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.03);
  }
  .sm-eyebrow__dot {
    width: 6px;
    height: 6px;
    border-radius: 999px;
    background: #5ba8ff;
    box-shadow: 0 0 10px rgba(91, 168, 255, 0.8);
    animation: sm-pulse 2.2s ease-in-out infinite;
  }
  @keyframes sm-pulse {
    0%, 100% { opacity: 0.5; }
    50% { opacity: 1; }
  }

  .sm-intro__headline {
    font-size: clamp(2.25rem, 5vw, 3.75rem);
    line-height: 1.02;
    letter-spacing: -0.035em;
    font-weight: 740;
    margin: 0 0 1rem;
    color: #fff;
  }
  .sm-intro__headline em {
    font-style: italic;
    color: #8fb4ff;
    font-weight: 500;
  }
  .sm-intro__sub {
    font-size: 1.1rem;
    line-height: 1.55;
    color: var(--sm-dark-type-dim);
    max-width: 34rem;
    margin: 0 0 2.25rem;
  }

  .sm-intro__stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    max-width: 34rem;
  }
  @media (max-width: 540px) { .sm-intro__stats { grid-template-columns: repeat(2, 1fr); } }
  .sm-stat {
    padding: 0.85rem 0.9rem;
    border: 1px solid var(--sm-dark-line);
    border-radius: 10px;
    background: rgba(255, 255, 255, 0.025);
    backdrop-filter: blur(4px);
  }
  .sm-stat__num {
    display: block;
    font-size: 1.5rem;
    font-weight: 600;
    color: #fff;
    letter-spacing: -0.02em;
    line-height: 1;
    margin-bottom: 0.35rem;
  }
  .sm-stat__lbl {
    display: block;
    font-size: 0.72rem;
    color: var(--sm-dark-type-mute);
    letter-spacing: 0.02em;
  }

  /* Side panel — the "rubric card" */
  .sm-intro__panel {
    position: relative;
    padding: 1.5rem 1.5rem 1.25rem;
    border: 1px solid var(--sm-dark-line-2);
    border-radius: 14px;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.05), rgba(255, 255, 255, 0.01));
    box-shadow: 0 24px 60px -20px rgba(0, 0, 0, 0.65), inset 0 1px 0 rgba(255, 255, 255, 0.06);
    transform: rotate(-0.6deg);
  }
  .sm-intro__panel::after {
    content: '';
    position: absolute;
    inset: -10px -10px auto auto;
    width: 60px;
    height: 60px;
    background: radial-gradient(circle, rgba(143, 180, 255, 0.35), transparent 70%);
    filter: blur(8px);
    pointer-events: none;
  }
  .sm-intro__panel-label {
    display: inline-block;
    color: var(--sm-accent-on-dark);
    font-size: 0.7rem;
    letter-spacing: 0.16em;
    padding: 0.2rem 0.55rem;
    border: 1px solid var(--sm-dark-line-2);
    border-radius: 4px;
    margin-bottom: 1rem;
  }
  .sm-intro__panel-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.55rem 1rem;
    margin-bottom: 1rem;
  }
  .sm-intro__panel-cell {
    display: flex;
    align-items: baseline;
    gap: 0.55rem;
    padding: 0.45rem 0;
    border-bottom: 1px dashed var(--sm-dark-line);
  }
  .sm-intro__panel-num {
    color: var(--sm-dark-type-mute);
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    flex-shrink: 0;
  }
  .sm-intro__panel-nm {
    color: var(--sm-dark-type);
    font-weight: 500;
    font-size: 0.92rem;
    letter-spacing: -0.01em;
  }
  .sm-intro__panel-foot {
    display: flex;
    justify-content: space-between;
    padding-top: 0.75rem;
    border-top: 1px solid var(--sm-dark-line);
    color: var(--sm-dark-type-mute);
    font-size: 0.68rem;
    letter-spacing: 0.12em;
  }

  /* ================================================================
     2. DIMENSIONS GRID
     ================================================================ */
  .sm-dim-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1rem;
  }
  @media (max-width: 1100px) { .sm-dim-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); } }
  @media (max-width: 820px)  { .sm-dim-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
  @media (max-width: 500px)  { .sm-dim-grid { grid-template-columns: 1fr; } }

  .sm-dim {
    position: relative;
    padding: 1.5rem 1.35rem 1.25rem;
    background: var(--color-canvas);
    border: 1px solid var(--color-line);
    border-radius: 14px;
    box-shadow: var(--shadow-xs);
    transition: transform .2s ease, border-color .2s ease, box-shadow .2s ease;
    display: flex;
    flex-direction: column;
    min-height: 300px;
  }
  .sm-dim:hover {
    transform: translateY(-3px);
    border-color: color-mix(in oklch, var(--color-accent) 35%, var(--color-line));
    box-shadow: var(--shadow-md), 0 0 0 3px var(--color-accent-softer);
  }
  .sm-dim__head {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 0.9rem;
  }
  .sm-dim__icon {
    width: 40px; height: 40px;
    display: inline-flex; align-items: center; justify-content: center;
    border-radius: 10px;
    background: var(--color-accent-soft);
    color: var(--color-accent);
    border: 1px solid color-mix(in oklch, var(--color-accent) 15%, var(--color-line));
  }
  .sm-dim__num {
    font-size: 0.72rem;
    color: var(--color-type-subtle);
    letter-spacing: 0.08em;
  }
  .sm-dim__name {
    font-size: 1.12rem;
    margin: 0 0 0.35rem;
    font-weight: 650;
    letter-spacing: -0.015em;
  }
  .sm-dim__measure {
    font-size: 0.88rem;
    color: var(--color-type-mute);
    line-height: 1.45;
    margin: 0 0 1.1rem;
  }

  /* 10-tick severity scale, fills on reveal */
  .sm-dim__scale {
    display: flex;
    gap: 3px;
    margin-bottom: 1rem;
  }
  .sm-dim__tick {
    flex: 1;
    height: 6px;
    border-radius: 2px;
    background: var(--color-surface-2);
    transform: scaleY(0.6);
    opacity: 0.7;
    transition: background .5s ease, opacity .5s ease, transform .5s ease;
    transition-delay: calc(var(--t) * 60ms + var(--i, 0) * 40ms);
  }
  .sm-reveal-root.is-in .sm-dim__tick {
    opacity: 1;
    transform: scaleY(1);
  }
  .sm-reveal-root.is-in .sm-dim__tick:nth-child(-n+4) { background: var(--color-accent); }
  .sm-reveal-root.is-in .sm-dim__tick:nth-child(n+5):nth-child(-n+7) { background: color-mix(in oklch, var(--color-accent) 55%, var(--color-surface-3)); }
  .sm-reveal-root.is-in .sm-dim__tick:nth-child(n+8) { background: color-mix(in oklch, var(--color-accent) 25%, var(--color-surface-3)); }

  .sm-dim__leader { margin-top: auto; }
  .sm-dim__leader-lbl {
    display: block;
    margin-bottom: 0.5rem;
    color: var(--color-type-mute);
    font-size: 0.68rem;
    letter-spacing: 0.1em;
  }
  .sm-dim__leader-list {
    list-style: none;
    padding: 0; margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }
  .sm-dim__pill {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.3rem 0.55rem;
    border-radius: 7px;
    background: var(--color-surface);
    border: 1px solid var(--color-line);
    font-size: 0.82rem;
  }
  .sm-dim__pill.is-first {
    background: var(--color-accent-soft);
    border-color: color-mix(in oklch, var(--color-accent) 25%, var(--color-line));
  }
  .sm-dim__pill-score {
    flex-shrink: 0;
    min-width: 22px;
    padding: 0.05rem 0.3rem;
    border-radius: 4px;
    background: var(--color-canvas);
    border: 1px solid var(--color-line);
    text-align: center;
    font-size: 0.76rem;
    font-weight: 600;
    color: var(--color-type);
  }
  .sm-dim__pill.is-first .sm-dim__pill-score {
    background: var(--color-accent);
    color: #fff;
    border-color: var(--color-accent);
  }
  .sm-dim__pill-name {
    color: var(--color-type-dim);
    font-weight: 500;
  }
  .sm-dim__pill.is-first .sm-dim__pill-name { color: var(--color-accent); font-weight: 600; }

  /* ================================================================
     3. LISTICLE WEIGHTING (dark band)
     ================================================================ */
  .sm-weights-band {
    background:
      radial-gradient(600px 300px at 15% 0%, rgba(21, 101, 181, 0.22), transparent 60%),
      linear-gradient(180deg, #0a0f1a 0%, #0e1524 100%);
    color: var(--sm-dark-type);
    padding: 4.5rem 0 5rem;
  }
  .sm-weights { padding: 0 1.5rem; }
  .sm-weights__head {
    max-width: 52rem;
    margin: 0 auto 2.75rem;
    text-align: center;
  }
  .sm-weights__head h3 {
    color: #fff;
    font-size: clamp(1.8rem, 3vw, 2.5rem);
    line-height: 1.08;
    letter-spacing: -0.025em;
    margin: 0.5rem 0 0.75rem;
  }
  .sm-weights__head h3 em { font-style: italic; color: #8fb4ff; font-weight: 500; }
  .sm-weights__sub {
    color: var(--sm-dark-type-dim);
    font-size: 1.0625rem;
    margin: 0;
  }

  .sm-weights__table {
    display: grid;
    gap: 0;
    border: 1px solid var(--sm-dark-line-2);
    border-radius: 14px;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.02);
    box-shadow: 0 24px 60px -20px rgba(0, 0, 0, 0.55);
  }
  .sm-weights__row {
    display: grid;
    grid-template-columns: minmax(14rem, 1.3fr) repeat(8, minmax(0, 1fr));
    align-items: center;
    gap: 0.6rem;
    padding: 0.85rem 1.1rem;
    border-bottom: 1px solid var(--sm-dark-line);
  }
  .sm-weights__row:last-child { border-bottom: 0; }
  .sm-weights__row--head {
    background: rgba(255, 255, 255, 0.04);
    padding-top: 0.75rem; padding-bottom: 0.75rem;
  }
  .sm-weights__intent {
    display: flex;
    flex-direction: column;
    gap: 0.12rem;
  }
  .sm-weights__intent-title {
    font-weight: 600;
    color: #fff;
    font-size: 0.95rem;
    letter-spacing: -0.01em;
  }
  .sm-weights__intent-sub {
    color: var(--sm-dark-type-mute);
    font-size: 0.76rem;
  }
  .sm-weights__col-head {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.15rem;
    text-align: center;
  }
  .sm-weights__col-head .mono {
    font-size: 0.68rem;
    color: var(--sm-dark-type-mute);
    letter-spacing: 0.08em;
  }
  .sm-weights__col-name {
    font-size: 0.72rem;
    color: var(--sm-dark-type-dim);
    font-weight: 500;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 100%;
  }

  .sm-weights__cell {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    align-items: center;
  }
  .sm-weights__bar {
    width: 100%;
    max-width: 64px;
    height: 8px;
    background: rgba(255, 255, 255, 0.07);
    border-radius: 999px;
    overflow: hidden;
    position: relative;
  }
  .sm-weights__bar-fill {
    display: block;
    height: 100%;
    width: 0;
    border-radius: 999px;
    background: #8fb4ff;
    transition: width 1s cubic-bezier(.2, .7, .2, 1);
    transition-delay: calc(var(--i, 0) * 80ms + 120ms);
  }
  .sm-reveal-root.is-in .sm-weights__bar-fill {
    width: calc(var(--w, 1) * 25%);
  }
  .sm-weights__bar--w1 .sm-weights__bar-fill,
  .sm-weights__legend-swatch.sm-weights__bar--w1 { background: rgba(200, 213, 239, 0.28); }
  .sm-weights__bar--w2 .sm-weights__bar-fill,
  .sm-weights__legend-swatch.sm-weights__bar--w2 { background: #6c90d8; }
  .sm-weights__bar--w3 .sm-weights__bar-fill,
  .sm-weights__legend-swatch.sm-weights__bar--w3 { background: #8fb4ff; }
  .sm-weights__bar--w4 .sm-weights__bar-fill,
  .sm-weights__legend-swatch.sm-weights__bar--w4 {
    background: linear-gradient(90deg, #c9dcff 0%, #fff 100%);
    box-shadow: 0 0 12px rgba(143, 180, 255, 0.5);
  }
  .sm-weights__cell-lbl {
    font-size: 0.62rem;
    color: var(--sm-dark-type-mute);
    letter-spacing: 0.08em;
  }

  @media (max-width: 960px) {
    /* On smaller screens, flip the table into a stack of mini-bars per listicle */
    .sm-weights__row--head { display: none; }
    .sm-weights__row {
      grid-template-columns: 1fr;
      gap: 0.75rem;
      padding: 1rem 1.1rem;
    }
    .sm-weights__intent { margin-bottom: 0.25rem; }
    .sm-weights__cell {
      flex-direction: row;
      width: 100%;
      gap: 0.75rem;
    }
    .sm-weights__cell::before {
      content: attr(title);
      flex: 0 0 10rem;
      color: var(--sm-dark-type-dim);
      font-size: 0.8rem;
    }
    .sm-weights__bar { max-width: none; flex: 1; }
  }

  .sm-weights__legend {
    display: flex;
    gap: 1.25rem;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    margin-top: 1.5rem;
    color: var(--sm-dark-type-dim);
    font-size: 0.8rem;
  }
  .sm-weights__legend-title {
    color: var(--sm-dark-type-mute);
    font-size: 0.7rem;
    letter-spacing: 0.14em;
  }
  .sm-weights__legend-item {
    display: inline-flex; align-items: center; gap: 0.5rem;
  }
  .sm-weights__legend-swatch {
    width: 28px; height: 6px; border-radius: 999px; display: inline-block;
  }

  /* ================================================================
     4. TEST STEPS
     ================================================================ */
  .sm-steps {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }
  @media (max-width: 1000px) { .sm-steps { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
  @media (max-width: 620px)  { .sm-steps { grid-template-columns: 1fr; } }

  .sm-step {
    position: relative;
    background: var(--color-canvas);
    border: 1px solid var(--color-line);
    border-radius: 14px;
    overflow: hidden;
    box-shadow: var(--shadow-xs);
    display: flex;
    flex-direction: column;
    transition: transform .2s ease, border-color .2s ease, box-shadow .2s ease;
  }
  .sm-step:hover {
    transform: translateY(-3px);
    border-color: color-mix(in oklch, var(--color-accent) 30%, var(--color-line));
    box-shadow: var(--shadow-md);
  }
  .sm-step__chrome {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.55rem 0.8rem;
    background: var(--color-surface);
    border-bottom: 1px solid var(--color-line);
  }
  .sm-step__dot {
    width: 9px; height: 9px; border-radius: 999px;
  }
  .sm-step__dot--red { background: #ec6a5e; }
  .sm-step__dot--amber { background: #f5bd4f; }
  .sm-step__dot--green { background: #62c554; }
  .sm-step__chrome-lbl {
    margin-left: auto;
    font-size: 0.68rem;
    color: var(--color-type-subtle);
    letter-spacing: 0.08em;
  }
  .sm-step__body {
    padding: 1.1rem 1.25rem 0;
  }
  .sm-step__num {
    display: inline-block;
    font-size: 0.72rem;
    color: var(--color-accent);
    letter-spacing: 0.14em;
    margin-bottom: 0.4rem;
  }
  .sm-step__title {
    margin: 0 0 0.35rem;
    font-size: 1.05rem;
    font-weight: 650;
    letter-spacing: -0.015em;
  }
  .sm-step__text {
    margin: 0 0 1.1rem;
    color: var(--color-type-mute);
    font-size: 0.9rem;
    line-height: 1.55;
  }

  /* Per-step mini-illustrations (pure CSS) */
  .sm-step__ill {
    border-top: 1px dashed var(--color-line);
    padding: 0.9rem 1.25rem 1.1rem;
    background: linear-gradient(180deg, var(--color-canvas), var(--color-canvas-tint));
    min-height: 110px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .ill-field {
    display: flex; align-items: center; justify-content: space-between;
    padding: 0.35rem 0.55rem;
    margin-bottom: 0.35rem;
    border: 1px solid var(--color-line);
    border-radius: 6px;
    background: var(--color-canvas);
    font-size: 0.78rem;
  }
  .ill-field-lbl { font-family: var(--font-mono); font-size: 0.66rem; color: var(--color-type-mute); letter-spacing: 0.08em; }
  .ill-field-val { color: var(--color-type); }
  .ill-signup { width: 100%; }
  .ill-btn {
    background: var(--color-accent);
    color: #fff;
    text-align: center;
    padding: 0.4rem 0.5rem;
    border-radius: 6px;
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    margin-top: 0.25rem;
  }

  .ill-feat { width: 100%; display: flex; flex-direction: column; gap: 0.3rem; }
  .ill-row {
    display: flex; align-items: center; gap: 0.5rem;
    padding: 0.3rem 0.5rem;
    background: var(--color-surface);
    border-radius: 6px;
    font-size: 0.8rem;
    color: var(--color-type-dim);
  }
  .ill-check { color: var(--color-success); font-weight: 700; }
  .ill-x { color: var(--color-danger); font-weight: 700; }

  .ill-search { width: 100%; }
  .ill-query {
    font-size: 0.72rem;
    color: var(--color-type);
    background: var(--color-surface);
    border: 1px solid var(--color-line);
    border-radius: 6px;
    padding: 0.4rem 0.55rem;
    margin-bottom: 0.5rem;
  }
  .ill-bars {
    display: flex; align-items: flex-end; gap: 4px;
    height: 46px;
  }
  .ill-bar {
    flex: 1; height: var(--h); background: var(--color-accent);
    border-radius: 3px 3px 0 0;
    opacity: 0.85;
    transform-origin: bottom;
    animation: sm-bar-grow 0.9s cubic-bezier(.2,.7,.2,1) both;
  }
  .ill-bar:nth-child(1) { animation-delay: 0.1s; }
  .ill-bar:nth-child(2) { animation-delay: 0.2s; }
  .ill-bar:nth-child(3) { animation-delay: 0.3s; background: color-mix(in oklch, var(--color-accent) 80%, #fff); }
  .ill-bar:nth-child(4) { animation-delay: 0.4s; }
  .ill-bar:nth-child(5) { animation-delay: 0.5s; }
  @keyframes sm-bar-grow { from { transform: scaleY(0); } to { transform: scaleY(1); } }

  .ill-lp {
    position: relative;
    width: 100%;
    height: 70px;
  }
  .ill-lp-win {
    position: absolute;
    left: 0; top: 4px;
    width: 60%; height: 60px;
    border: 1px solid var(--color-line);
    border-radius: 6px;
    background:
      linear-gradient(var(--color-surface) 0 12px, transparent 12px),
      repeating-linear-gradient(180deg, var(--color-surface-2) 0 4px, var(--color-canvas) 4px 10px);
  }
  .ill-lp-zip {
    position: absolute;
    right: 0; top: 0;
    width: 42%;
    padding: 0.45rem 0.55rem;
    border: 1px solid color-mix(in oklch, var(--color-accent) 30%, var(--color-line));
    border-radius: 6px;
    background: var(--color-accent-soft);
    font-size: 0.72rem;
    color: var(--color-accent);
    line-height: 1.25;
    font-family: var(--font-mono);
  }
  .ill-lp-zip span { color: var(--color-accent); opacity: 0.7; font-size: 0.66rem; }

  .ill-api { width: 100%; }
  .ill-code {
    background: #0a0f1a;
    color: #e4e8ee;
    border-radius: 6px;
    padding: 0.6rem 0.75rem;
    font-size: 0.76rem;
    line-height: 1.55;
  }
  .ill-code .c-mute { color: rgba(255,255,255,0.45); }
  .ill-code .c-ok { color: #7fe0a3; }

  .ill-price { width: 100%; }
  .ill-price-row {
    display: flex; justify-content: space-between; align-items: center;
    padding: 0.4rem 0.55rem;
    border: 1px solid var(--color-line);

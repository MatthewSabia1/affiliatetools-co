---
/**
 * UseCaseScenarios.astro — Persona verdict cards for versus pages.
 * Each card shows a persona, verdict, and a recommendation chip.
 */
export type Recommendation = 'adrecon' | 'competitor' | 'both' | 'other';

export interface Scenario {
  persona: string;
  verdict: string;
  recommendation: Recommendation;
  competitorName?: string;
}

export interface Props {
  scenarios: Scenario[];
  heading?: string;
  eyebrow?: string;
}

const {
  scenarios,
  heading = 'Who should use which?',
  eyebrow = 'Use cases',
} = Astro.props;

const chipClassFor = (rec: Recommendation): string => {
  switch (rec) {
    case 'adrecon':
      return 'chip chip-gold';
    case 'competitor':
      return 'chip chip-warning';
    case 'both':
      return 'chip chip-green';
    default:
      return 'chip';
  }
};

const pickLabelFor = (scenario: Scenario): string => {
  if (scenario.recommendation === 'adrecon') return 'Our pick: AdRecon';
  if (scenario.recommendation === 'competitor') {
    return scenario.competitorName ? `Our pick: ${scenario.competitorName}` : 'Our pick: Competitor';
  }
  if (scenario.recommendation === 'both') return 'Our pick: Use both';
  return scenario.competitorName ? `Our pick: ${scenario.competitorName}` : 'Our pick: Look elsewhere';
};
---

<section class="scenarios" aria-label={heading}>
  <header class="scenarios__header">
    <p class="label-mono">{eyebrow}</p>
    <h3 class="scenarios__title">{heading}</h3>
  </header>

  <div class="scenarios__grid">
    {scenarios.map((scenario) => (
      <article class="scenario-card">
        <h4 class="scenario-card__persona">{scenario.persona}</h4>
        <p class="scenario-card__verdict">{scenario.verdict}</p>
        <span class={chipClassFor(scenario.recommendation)}>
          {pickLabelFor(scenario)}
        </span>
      </article>
    ))}
  </div>
</section>

<style>
  .scenarios {
    margin: 2rem 0;
  }
  .scenarios__header {
    margin-bottom: 1rem;
  }
  .scenarios__title {
    font-family: var(--font-sans);
    font-size: 1.35rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0.3rem 0 0;
  }

  .scenarios__grid {
    display: grid;
    gap: 0.85rem;
    grid-template-columns: repeat(2, 1fr);
  }
  @media (max-width: 720px) {
    .scenarios__grid { grid-template-columns: 1fr; }
  }

  .scenario-card {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    padding: 1.1rem 1.15rem;
    background: var(--color-surface);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-md);
    transition: transform 0.15s ease, box-shadow 0.15s ease, border-color 0.15s ease;
  }
  .scenario-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-card);
    border-color: var(--color-line-strong);
  }

  .scenario-card__persona {
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    margin: 0;
    color: var(--color-type);
  }
  .scenario-card__verdict {
    margin: 0;
    color: var(--color-ink-dim);
    font-size: 0.95rem;
    line-height: 1.55;
  }
  .scenario-card .chip {
    align-self: flex-start;
  }
</style>

---
/**
 * Horizontal breadcrumb trail. Last item is the current page (no link).
 * Semantic <ol>, aria-label="Breadcrumb".
 */

interface Props {
  items: Array<{ name: string; href?: string }>;
}

const { items } = Astro.props;
const total = items.length;
---

<nav aria-label="Breadcrumb" class="breadcrumb">
  <ol class="breadcrumb__list">
    {
      items.map((item, i) => {
        const isLast = i === total - 1;
        return (
          <li class="breadcrumb__item">
            {item.href && !isLast ? (
              <a href={item.href} class="breadcrumb__link">{item.name}</a>
            ) : (
              <span
                class="breadcrumb__current"
                aria-current={isLast ? 'page' : undefined}
              >
                {item.name}
              </span>
            )}
            {!isLast && <span class="breadcrumb__sep" aria-hidden="true">/</span>}
          </li>
        );
      })
    }
  </ol>
</nav>

<style>
  .breadcrumb {
    font-size: 0.85rem;
    line-height: 1.3;
    color: var(--color-ink-subtle);
  }
  .breadcrumb__list {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.45rem;
    padding: 0;
    margin: 0;
  }
  .breadcrumb__item {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    margin: 0;
    color: inherit;
  }
  .breadcrumb__link {
    color: var(--color-ink-mute);
    text-decoration: none;
    transition: color 0.15s ease;
  }
  .breadcrumb__link:hover {
    color: var(--color-gold);
    text-decoration: underline;
    text-decoration-color: color-mix(in oklch, var(--color-gold) 50%, transparent);
  }
  .breadcrumb__current {
    color: var(--color-ink-subtle);
  }
  .breadcrumb__sep {
    color: var(--color-line-strong);
    user-select: none;
  }
</style>

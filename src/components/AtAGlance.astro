---
/**
 * Sidebar summary card — "At a glance".
 * Loads competitor data via getCompetitor(slug) and renders a condensed scorecard.
 * Intended for review/versus pages (sticky on desktop).
 */
import ToolLogo from "@/components/ToolLogo.astro";
import { getCompetitor, overallScore } from "@/lib/competitors";
import type { CompetitorSlug } from "@/lib/constants";
import { DATA_AS_OF, routes } from "@/lib/constants";
import { formatStartingPrice } from "@/lib/pricing";

interface Props {
  slug: CompetitorSlug;
}

const { slug } = Astro.props;
const entry = await getCompetitor(slug);
const c = entry.data;

const score = overallScore(c.scores);

// Select the top 3 scorecard dimensions to surface.
const scoreEntries = Object.entries(c.scores) as Array<
  [keyof typeof c.scores, number]
>;
const topThree = [...scoreEntries].sort((a, b) => b[1] - a[1]).slice(0, 3);

const niceNames: Record<keyof typeof c.scores, string> = {
  coverage: "Coverage",
  dataFreshness: "Data freshness",
  price: "Value",
  ux: "UX",
  landingPages: "Landing pages",
  offers: "Offers",
  affiliateFocus: "Affiliate fit",
  search: "Search",
};

const startLabel = formatStartingPrice(c.pricing, {
  prefixFrom: true,
  freeLabel: "Free tier available",
});
---

<aside
  class="at-a-glance card card-accent sticky-sidebar"
  aria-label="At a glance"
>
  <header class="at-a-glance__header">
    <ToolLogo slug={slug} size="md" />
    <div class="at-a-glance__identity">
      <p class="label-mono">At a glance</p>
      <h3 class="at-a-glance__name">{c.name}</h3>
    </div>
  </header>

  <dl class="at-a-glance__stats">
    <div class="at-a-glance__stat">
      <dt class="label-mono">Starting price</dt>
      <dd class="at-a-glance__price">
        {startLabel}
        <span class="at-a-glance__asof">as of {DATA_AS_OF}</span>
      </dd>
    </div>
    <div class="at-a-glance__stat">
      <dt class="label-mono">Overall score</dt>
      <dd class="at-a-glance__score">
        <span class="at-a-glance__score-value">{score.toFixed(1)}</span>
        <span class="at-a-glance__score-outof">/ 10</span>
      </dd>
    </div>
  </dl>

  <div class="at-a-glance__scorecard">
    <p class="label-mono">Top dimensions</p>
    <ul class="at-a-glance__bars">
      {
        topThree.map(([key, val]) => (
          <li class="at-a-glance__bar-row">
            <span class="at-a-glance__bar-label">{niceNames[key]}</span>
            <span class="at-a-glance__bar-track" aria-hidden="true">
              <span
                class="at-a-glance__bar-fill"
                style={`width:${(val / 10) * 100}%`}
              />
            </span>
            <span class="at-a-glance__bar-value">{val.toFixed(1)}</span>
          </li>
        ))
      }
    </ul>
  </div>

  <p class="at-a-glance__best-for">
    <span class="label-mono">Best for</span>
    <span>{c.bestFor[0]}</span>
  </p>

  {
    c.externalRatings && c.externalRatings.length > 0 && (
      <div class="at-a-glance__external">
        <p class="label-mono">External sources</p>
        <ul class="at-a-glance__external-list">
          {c.externalRatings.map((r) => (
            <li class="at-a-glance__external-row">
              <a href={r.url} rel="nofollow noopener">
                {r.source}
              </a>
              <span class="at-a-glance__external-rating">
                {r.rating !== null ? `${r.rating}/${r.outOf}` : "—"}
                {typeof r.reviewCount === "number" && r.reviewCount > 0 ? (
                  <span class="at-a-glance__external-count">
                    {" "}
                    · {r.reviewCount.toLocaleString()} reviews
                  </span>
                ) : null}
              </span>
            </li>
          ))}
        </ul>
      </div>
    )
  }

  <div class="at-a-glance__ctas">
    <a class="btn btn-secondary" href={c.homepageUrl} rel="nofollow noopener">
      Visit official site
    </a>
    <a class="btn btn-secondary" href={routes.methodology()}>
      Read methodology
    </a>
  </div>
</aside>

<style>
  .at-a-glance {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .at-a-glance__header {
    display: flex;
    gap: 0.85rem;
    align-items: center;
  }
  .at-a-glance__identity .label-mono {
    margin: 0;
  }
  .at-a-glance__name {
    margin: 0.25rem 0 0;
    font-size: 1.25rem;
    color: var(--color-type);
  }
  .at-a-glance__stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin: 0;
    padding-top: 1rem;
    border-top: 1px solid var(--color-line);
  }
  .at-a-glance__stat dt {
    margin: 0 0 0.3rem;
  }
  .at-a-glance__stat dd {
    margin: 0;
  }
  .at-a-glance__price {
    color: var(--color-type);
    font-weight: 600;
    font-size: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }
  .at-a-glance__asof {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 400;
    color: var(--color-ink-subtle);
    letter-spacing: 0.02em;
  }
  .at-a-glance__score {
    display: flex;
    align-items: baseline;
    gap: 0.25rem;
    color: var(--color-gold);
    font-family: var(--font-serif);
  }
  .at-a-glance__score-value {
    font-size: 2.1rem;
    line-height: 1;
  }
  .at-a-glance__score-outof {
    color: var(--color-ink-subtle);
    font-family: var(--font-mono);
    font-size: 0.78rem;
  }

  .at-a-glance__scorecard .label-mono {
    margin: 0 0 0.6rem;
  }
  .at-a-glance__bars {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .at-a-glance__bar-row {
    display: grid;
    grid-template-columns: 5.5rem 1fr 2ch;
    align-items: center;
    gap: 0.65rem;
    margin: 0;
    font-size: 0.82rem;
    color: var(--color-ink-dim);
  }
  .at-a-glance__bar-label {
    color: var(--color-ink-mute);
  }
  .at-a-glance__bar-track {
    display: block;
    height: 6px;
    background: var(--color-surface-2);
    border: 1px solid var(--color-line);
    border-radius: 3px;
    overflow: hidden;
  }
  .at-a-glance__bar-fill {
    display: block;
    height: 100%;
    background: linear-gradient(
      90deg,
      color-mix(in oklch, var(--color-gold) 70%, transparent),
      var(--color-gold)
    );
  }
  .at-a-glance__bar-value {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--color-type);
    text-align: right;
  }

  .at-a-glance__best-for {
    margin: 0;
    padding: 0.85rem 0;
    border-top: 1px solid var(--color-line);
    border-bottom: 1px solid var(--color-line);
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    color: var(--color-ink-dim);
    font-size: 0.9rem;
    line-height: 1.45;
  }
  .at-a-glance__best-for .label-mono {
    margin: 0;
  }

  .at-a-glance__external .label-mono {
    margin: 0 0 0.55rem;
  }
  .at-a-glance__external-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }
  .at-a-glance__external-row {
    margin: 0;
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 0.75rem;
    font-size: 0.85rem;
    color: var(--color-ink-dim);
  }
  .at-a-glance__external-row a {
    color: var(--color-type);
    text-decoration: none;
  }
  .at-a-glance__external-row a:hover {
    color: var(--color-gold);
    text-decoration: underline;
  }
  .at-a-glance__external-rating {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-ink-mute);
  }
  .at-a-glance__external-count {
    color: var(--color-ink-subtle);
  }

  .at-a-glance__ctas {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-top: 0.25rem;
  }
  .at-a-glance__ctas .btn {
    width: 100%;
  }
</style>

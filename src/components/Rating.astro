---
/**
 * Rating.astro — Directory-tier editorial score readout.
 * Elegant typographic treatment: oversized tabular numeral + /10 subscript
 * + inline severity underline. Supports both light and dark surface themes.
 */
import { scoreSeverity } from '@/lib/competitors';

export interface Props {
  value: number;
  size?: 'sm' | 'md' | 'lg';
  theme?: 'light' | 'dark';
  showLabel?: boolean;
  /** Optional descriptor displayed below the score (e.g. "overall") */
  label?: string;
}

const {
  value,
  size = 'md',
  theme = 'light',
  showLabel = false,
  label = 'overall',
} = Astro.props;

const clamped = Math.max(1, Math.min(10, value));
const display = (Math.round(clamped * 10) / 10).toFixed(1);
const severity = scoreSeverity(clamped);
const fillPct = Math.max(8, clamped * 10);
---

<span
  class:list={['rating', `rating--${size}`, `rating--${theme}`, `rating--${severity}`]}
  role="img"
  aria-label={`Score: ${display} out of 10`}
>
  <span class="rating__num">
    <span class="rating__int">{display}</span>
    <span class="rating__max">/10</span>
  </span>
  <span class="rating__track" aria-hidden="true">
    <span class="rating__fill" style={`width: ${fillPct}%;`}></span>
  </span>
  {showLabel && <span class="rating__lbl">{label}</span>}
</span>

<style>
  .rating {
    display: inline-flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.35rem;
    line-height: 1;
    min-width: 3.8rem;
  }

  .rating__num {
    display: inline-flex;
    align-items: baseline;
    gap: 0.18rem;
    font-family: var(--font-sans);
    font-variant-numeric: tabular-nums;
    letter-spacing: -0.035em;
    line-height: 1;
  }
  .rating__int {
    font-weight: 780;
    font-size: 2.25rem;
  }
  .rating__max {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.01em;
  }

  .rating__track {
    position: relative;
    display: block;
    width: 100%;
    height: 2px;
    border-radius: 2px;
    overflow: hidden;
  }
  .rating__fill {
    position: absolute;
    inset: 0 auto 0 0;
    height: 100%;
    border-radius: 2px;
    transition: width .8s cubic-bezier(.2,.9,.3,1) .1s;
  }

  .rating__lbl {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-weight: 500;
    margin-top: 0.15rem;
  }

  /* ---- Sizes ---- */
  .rating--sm .rating__int { font-size: 1.6rem; }
  .rating--sm .rating__max { font-size: 0.62rem; }
  .rating--sm { min-width: 3rem; }

  .rating--md .rating__int { font-size: 2.25rem; }

  .rating--lg .rating__int { font-size: 3rem; }
  .rating--lg .rating__max { font-size: 0.86rem; }
  .rating--lg { min-width: 5rem; }

  /* ---- Light theme ---- */
  .rating--light .rating__int { color: var(--color-type); }
  .rating--light .rating__max { color: var(--color-type-subtle); }
  .rating--light .rating__track { background: rgba(11, 20, 32, 0.08); }
  .rating--light .rating__lbl { color: var(--color-type-subtle); }
  .rating--light.rating--high .rating__fill {
    background: linear-gradient(90deg, var(--color-success) 0%, color-mix(in oklch, var(--color-success) 60%, white) 100%);
  }
  .rating--light.rating--med .rating__fill {
    background: linear-gradient(90deg, var(--color-warning) 0%, color-mix(in oklch, var(--color-warning) 60%, white) 100%);
  }
  .rating--light.rating--low .rating__fill {
    background: linear-gradient(90deg, var(--color-danger) 0%, color-mix(in oklch, var(--color-danger) 60%, white) 100%);
  }

  /* ---- Dark theme ---- */
  .rating--dark .rating__int { color: #ffffff; }
  .rating--dark .rating__max { color: rgba(255, 255, 255, 0.5); }
  .rating--dark .rating__track { background: rgba(255, 255, 255, 0.1); }
  .rating--dark .rating__lbl { color: rgba(255, 255, 255, 0.45); }
  .rating--dark.rating--high .rating__fill {
    background: linear-gradient(90deg, #34d399 0%, #a7f3d0 100%);
  }
  .rating--dark.rating--med .rating__fill {
    background: linear-gradient(90deg, #f59e0b 0%, #fcd34d 100%);
  }
  .rating--dark.rating--low .rating__fill {
    background: linear-gradient(90deg, #f87171 0%, #fecaca 100%);
  }
</style>

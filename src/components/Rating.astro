---
/**
 * Rating.astro — Big rounded pill showing a 1–10 score.
 * Color-coded by severity (red < 5, amber 5–7.4, green ≥ 7.5).
 */
import { scoreSeverity } from '@/lib/competitors';

export interface Props {
  value: number;
  showLabel?: boolean;
  size?: 'sm' | 'md' | 'lg';
}

const { value, showLabel = false, size = 'md' } = Astro.props;

const clamped = Math.max(1, Math.min(10, value));
const display = (Math.round(clamped * 10) / 10).toFixed(1);
const severity = scoreSeverity(clamped);
---

<span
  class:list={['rating-pill', `size-${size}`, `sev-${severity}`]}
  role="img"
  aria-label={`Score: ${display} out of 10`}
>
  {showLabel && <span class="rating-label label-mono">AffiliateTools score</span>}
  <div class="rating-body">
    <span class="rating-number">{display}</span>
    <span class="rating-max">/ 10</span>
  </div>
</span>

<style>
  .rating-pill {
    display: inline-flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.28rem;
    padding: 0.85rem 1rem;
    border-radius: 18px;
    border: 1px solid var(--color-line-2);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.9), rgba(247, 248, 250, 0.98)),
      var(--color-surface-2);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.75),
      0 12px 24px -20px rgba(11, 20, 32, 0.35);
    min-width: 6.4rem;
    line-height: 1;
  }
  .rating-label {
    color: var(--color-ink-subtle);
  }
  .rating-body {
    display: inline-flex;
    align-items: baseline;
    gap: 0.35rem;
    line-height: 1;
  }
  .rating-number {
    font-family: var(--font-sans);
    font-weight: 800;
    font-size: 2.15rem;
    letter-spacing: -0.03em;
    color: var(--color-type);
  }
  .rating-max {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--color-ink-subtle);
    font-weight: 500;
  }
  .size-sm {
    min-width: 5.15rem;
    padding: 0.65rem 0.82rem;
    border-radius: 16px;
  }
  .size-sm .rating-number {
    font-size: 1.68rem;
  }
  .size-sm .rating-max {
    font-size: 0.7rem;
  }
  .size-lg {
    min-width: 7.2rem;
    padding: 0.95rem 1.1rem;
  }
  .size-lg .rating-number {
    font-size: 2.45rem;
  }
  .size-lg .rating-max {
    font-size: 0.84rem;
  }

  .sev-high {
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.82), rgba(255, 255, 255, 0.24)),
      color-mix(in oklch, var(--color-success) 18%, var(--color-surface-2));
    border-color: color-mix(in oklch, var(--color-success) 34%, var(--color-line));
  }
  .sev-high .rating-number { color: var(--color-success); }

  .sev-med {
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.82), rgba(255, 255, 255, 0.24)),
      color-mix(in oklch, var(--color-warning) 16%, var(--color-surface-2));
    border-color: color-mix(in oklch, var(--color-warning) 32%, var(--color-line));
  }
  .sev-med .rating-number { color: var(--color-warning); }

  .sev-low {
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.82), rgba(255, 255, 255, 0.24)),
      color-mix(in oklch, var(--color-danger) 16%, var(--color-surface-2));
    border-color: color-mix(in oklch, var(--color-danger) 32%, var(--color-line));
  }
  .sev-low .rating-number { color: var(--color-danger); }
</style>

---
/**
 * Footer — comprehensive, SaaS-tier. Five-column grid with full site map, legal, and disclosure.
 */
import {
  COMPETITOR_NAMES,
  VERSUS_SLUGS,
  COMPETITOR_SLUGS,
  LISTICLE_SLUGS,
  ADRECON_HOME_URL,
  routes,
  SITE_NAME,
} from '@/lib/constants';

const reviewCols = COMPETITOR_SLUGS.map((slug) => ({
  href: routes.review(slug),
  label: COMPETITOR_NAMES[slug],
}));

const versusCols = VERSUS_SLUGS.slice(0, 6).map((slug) => ({
  href: routes.versus(slug),
  label: `AdRecon vs ${COMPETITOR_NAMES[slug]}`,
}));

const listicleLabels: Record<(typeof LISTICLE_SLUGS)[number], string> = {
  'best-ad-spy-tools-2026': 'Best ad spy tools 2026',
  'best-ad-spy-tools-for-affiliate-marketers': 'Best for affiliate marketers',
  'best-ad-spy-tools-for-facebook-ads': 'Best for Facebook ads',
  'best-ad-spy-tools-for-clickbank': 'Best for ClickBank',
  'adspy-alternatives': 'AdSpy alternatives',
  'best-free-ad-spy-tools': 'Best free ad spy tools',
};

const guideCols = LISTICLE_SLUGS.map((slug) => ({
  href: routes.listicle(slug),
  label: listicleLabels[slug],
}));

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container-wide site-footer__inner">
    <div class="site-footer__top">
      <div class="site-footer__brand">
        <a class="site-footer__logo" href="/" aria-label={`${SITE_NAME} home`}>
          <svg width="28" height="28" viewBox="0 0 24 24" aria-hidden="true">
            <rect x="2" y="2" width="20" height="20" rx="5" fill="currentColor" opacity="0.12"/>
            <path d="M7 15 L12 6 L17 15 M9 12 H15" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
          </svg>
          <span class="site-footer__logo-name">AffiliateTools<span class="site-footer__logo-tld">.co</span></span>
        </a>
        <p class="site-footer__tagline">
          Independent, hands-on reviews of the software affiliate marketers actually run. Operated by the <a href={ADRECON_HOME_URL} rel="noopener">AdRecon</a> team — and we disclose that openly.
        </p>
        <div class="site-footer__badges">
          <span class="site-footer__badge">Editorial independence</span>
          <span class="site-footer__badge">Zero paid placements</span>
          <span class="site-footer__badge">Updated quarterly</span>
        </div>
      </div>

      <div class="site-footer__cols">
        <div class="site-footer__col">
          <h3 class="site-footer__heading">Reviews</h3>
          <ul class="site-footer__list">
            {reviewCols.map((l) => (
              <li><a href={l.href}>{l.label}</a></li>
            ))}
          </ul>
        </div>

        <div class="site-footer__col">
          <h3 class="site-footer__heading">Comparisons</h3>
          <ul class="site-footer__list">
            {versusCols.map((l) => (
              <li><a href={l.href}>{l.label}</a></li>
            ))}
            <li><a href={routes.hub()}>All comparisons →</a></li>
          </ul>
        </div>

        <div class="site-footer__col">
          <h3 class="site-footer__heading">Rankings</h3>
          <ul class="site-footer__list">
            {guideCols.map((l) => (
              <li><a href={l.href}>{l.label}</a></li>
            ))}
          </ul>
        </div>

        <div class="site-footer__col">
          <h3 class="site-footer__heading">Company</h3>
          <ul class="site-footer__list">
            <li><a href={routes.about()}>About</a></li>
            <li><a href={routes.methodology()}>Methodology</a></li>
            <li><a href="/disclosure/">Editorial disclosure</a></li>
            <li><a href={routes.contact()}>Contact</a></li>
            <li><a href="/sitemap/">Site map</a></li>
          </ul>

          <h3 class="site-footer__heading" style="margin-top: 1.8rem;">Legal</h3>
          <ul class="site-footer__list">
            <li><a href="/privacy/">Privacy Policy</a></li>
            <li><a href="/terms/">Terms of Service</a></li>
            <li><a href="/cookies/">Cookie Policy</a></li>
          </ul>
        </div>
      </div>
    </div>

    <div class="site-footer__legal">
      <p class="site-footer__copy">
        © {year} {SITE_NAME} · All trademarks are property of their respective owners.
      </p>
      <p class="site-footer__fine">
        AffiliateTools.co is operated by <a href={ADRECON_HOME_URL} rel="noopener">AdRecon</a>, a Meta-focused ad intelligence platform. AdRecon is a competitor to most tools reviewed on this site. See our <a href={routes.methodology()}>methodology</a> and <a href="/disclosure/">editorial disclosure</a>.
      </p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 6rem;
    border-top: 1px solid var(--color-line);
    background: var(--color-surface);
  }
  .site-footer__inner {
    padding-top: 4rem;
    padding-bottom: 2.5rem;
  }

  .site-footer__top {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }
  @media (min-width: 1024px) {
    .site-footer__top { grid-template-columns: 1fr 2.2fr; gap: 4rem; }
  }

  .site-footer__brand { max-width: 22rem; }
  .site-footer__logo {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    text-decoration: none;
    color: var(--color-accent);
    font-size: 1.15rem;
    font-weight: 700;
    letter-spacing: -0.02em;
  }
  .site-footer__logo:hover { text-decoration: none; color: var(--color-accent-hover); }
  .site-footer__logo-name { color: var(--color-type); }
  .site-footer__logo-tld { color: var(--color-type-mute); font-weight: 500; }

  .site-footer__tagline {
    margin: 1rem 0 0;
    color: var(--color-type-dim);
    font-size: 0.95rem;
    line-height: 1.6;
  }
  .site-footer__tagline a { color: var(--color-accent); }

  .site-footer__badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 1.25rem;
  }
  .site-footer__badge {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.7rem;
    color: var(--color-type-mute);
    font-weight: 500;
    letter-spacing: -0.005em;
    padding: 0.22rem 0.6rem;
    border-radius: 999px;
    background: var(--color-canvas);
    border: 1px solid var(--color-line);
  }
  .site-footer__badge::before {
    content: "";
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--color-success);
  }

  .site-footer__cols {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem 2.5rem;
  }
  @media (min-width: 768px) {
    .site-footer__cols { grid-template-columns: repeat(4, 1fr); }
  }

  .site-footer__heading {
    font-size: 0.78rem;
    font-family: var(--font-sans);
    font-weight: 650;
    color: var(--color-type);
    letter-spacing: -0.005em;
    margin: 0 0 0.85rem;
  }
  .site-footer__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }
  .site-footer__list li { margin: 0; }
  .site-footer__list a {
    color: var(--color-type-dim);
    text-decoration: none;
    font-size: 0.88rem;
    font-weight: 450;
    line-height: 1.4;
    transition: color 0.15s ease;
  }
  .site-footer__list a:hover { color: var(--color-accent); text-decoration: none; }

  .site-footer__legal {
    margin-top: 3.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-line);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .site-footer__copy {
    margin: 0;
    color: var(--color-type-mute);
    font-size: 0.8rem;
  }
  .site-footer__fine {
    margin: 0;
    color: var(--color-type-subtle);
    font-size: 0.78rem;
    line-height: 1.55;
    max-width: 58rem;
  }
</style>

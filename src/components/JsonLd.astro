---
/**
 * Utility to emit JSON-LD schema blocks.
 * Accepts a single object or an array of objects; emits one <script> per item.
 */
interface Props {
  data: object | object[];
}

const { data } = Astro.props;
const blocks = Array.isArray(data) ? data : [data];
---

{blocks.map((block) => (
  <script is:inline type="application/ld+json" set:html={JSON.stringify(block)} />
))}

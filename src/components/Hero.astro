---
/**
 * Hero — clean SaaS tier. No decoration. Just type + CTAs.
 */

interface CTA {
  href: string;
  label: string;
  rel?: string;
}

interface Props {
  eyebrow?: string;
  title: string;
  sub?: string;
  updatedDate?: string;
  primaryCta?: CTA;
  secondaryCta?: CTA;
  variant?: 'default' | 'compact';
}

const {
  eyebrow,
  title,
  sub,
  updatedDate,
  primaryCta,
  secondaryCta,
  variant = 'default',
} = Astro.props;

function formatUpdated(d?: string): string | null {
  if (!d) return null;
  const parsed = new Date(d);
  if (isNaN(parsed.getTime())) return d;
  return parsed.toLocaleDateString('en-US', { month: 'long', year: 'numeric' });
}

const updatedLabel = formatUpdated(updatedDate);

// Strip any stray <em> tags the page might have passed from the old design.
const cleanTitle = title.replace(/<\/?em>/g, '').replace(/<\/?i>/g, '');
---

<section class:list={['hero', `hero--${variant}`]}>
  <div class="container-max hero__inner">
    {eyebrow && <p class="hero__eyebrow">{eyebrow}</p>}
    <h1 class="hero__title">{cleanTitle}</h1>
    {sub && <p class="hero__sub">{sub}</p>}

    <div class="hero__meta">
      {updatedLabel && <span class="hero__updated">Updated {updatedLabel}</span>}
      <slot />
    </div>

    {(primaryCta || secondaryCta) && (
      <div class="hero__ctas">
        {primaryCta && (
          <a class="btn btn-primary btn-lg" href={primaryCta.href} rel="noopener">
            {primaryCta.label}
          </a>
        )}
        {secondaryCta && (
          <a class="btn btn-secondary btn-lg" href={secondaryCta.href} rel={secondaryCta.rel ?? 'noopener'}>
            {secondaryCta.label}
          </a>
        )}
      </div>
    )}
  </div>
</section>

<style>
  .hero {
    padding: 4rem 0 3rem;
    background: linear-gradient(180deg, var(--color-canvas-tint) 0%, var(--color-canvas) 100%);
    border-bottom: 1px solid var(--color-line);
  }
  .hero--default { padding: 4.5rem 0 3.5rem; }
  .hero--compact { padding: 2.5rem 0 2rem; }

  .hero__inner { max-width: 52rem; }

  .hero__eyebrow {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
    font-weight: 600;
    margin: 0 0 1rem;
  }

  .hero__title {
    margin: 0;
    color: var(--color-type);
    font-size: clamp(2.3rem, 4.6vw, 3.6rem);
    line-height: 1.08;
    font-weight: 740;
    letter-spacing: -0.03em;
  }
  .hero--compact .hero__title { font-size: clamp(1.9rem, 3.2vw, 2.6rem); line-height: 1.15; }

  .hero__sub {
    margin: 1.1rem 0 0;
    color: var(--color-type-dim);
    font-size: clamp(1.05rem, 1.3vw, 1.18rem);
    line-height: 1.55;
    max-width: 44rem;
    font-weight: 420;
  }

  .hero__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: center;
    margin-top: 1.25rem;
    font-size: 0.84rem;
    color: var(--color-type-mute);
  }
  .hero__updated {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.22rem 0.65rem;
    background: var(--color-surface);
    border: 1px solid var(--color-line);
    border-radius: 999px;
    color: var(--color-type-dim);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 500;
  }
  .hero__updated::before {
    content: "";
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-success);
    display: inline-block;
  }

  .hero__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-top: 1.75rem;
  }
</style>

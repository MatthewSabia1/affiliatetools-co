---
/**
 * ProsCons.astro — Two-column grid of strengths vs weaknesses from competitor YAML.
 */
import { getCompetitor } from '@/lib/competitors';
import type { CompetitorSlug } from '@/lib/constants';

export interface Props {
  slug: CompetitorSlug;
}

const { slug } = Astro.props;
const competitor = await getCompetitor(slug);
const { name, strengths, weaknesses } = competitor.data;
---

<section class="proscons card" aria-label={`${name} pros and cons`}>
  <header class="proscons__header">
    <p class="label-mono">Pros &amp; cons</p>
    <h3 class="proscons__title">What {name} does well — and where it falls short</h3>
  </header>

  <div class="proscons__grid">
    <div class="proscons__col proscons__col--pros">
      <h4 class="proscons__subhead">
        <span class="proscons__dot" aria-hidden="true"></span>
        Pros
      </h4>
      <ul role="list">
        {strengths.map((item) => (
          <li>
            <svg class="proscons__icon" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <circle cx="8" cy="8" r="7.25" stroke="currentColor" stroke-width="1.2" opacity="0.35" />
              <path d="M4.5 8.25L7 10.75L11.75 5.75" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
            <span>{item}</span>
          </li>
        ))}
      </ul>
    </div>

    <div class="proscons__col proscons__col--cons">
      <h4 class="proscons__subhead">
        <span class="proscons__dot" aria-hidden="true"></span>
        Cons
      </h4>
      <ul role="list">
        {weaknesses.map((item) => (
          <li>
            <svg class="proscons__icon" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <circle cx="8" cy="8" r="7.25" stroke="currentColor" stroke-width="1.2" opacity="0.35" />
              <path d="M5.25 5.25L10.75 10.75M10.75 5.25L5.25 10.75" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
            <span>{item}</span>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>

<style>
  .proscons {
    padding: 1.5rem;
  }
  .proscons__header {
    margin-bottom: 1.25rem;
  }
  .proscons__title {
    font-family: var(--font-sans);
    font-size: 1.25rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0.2rem 0 0;
    line-height: 1.3;
  }

  .proscons__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  @media (max-width: 640px) {
    .proscons__grid { grid-template-columns: 1fr; }
  }

  .proscons__col {
    padding: 1.1rem;
    border-radius: var(--radius-md);
    border: 1px solid var(--color-line);
    background: var(--color-surface-2);
  }
  .proscons__col--pros {
    border-color: color-mix(in oklch, var(--color-success) 35%, var(--color-line));
    background: color-mix(in oklch, var(--color-green-soft) 55%, var(--color-surface-2));
  }
  .proscons__col--cons {
    border-color: color-mix(in oklch, var(--color-danger) 35%, var(--color-line));
    background: color-mix(in oklch, var(--color-danger) 8%, var(--color-surface-2));
  }

  .proscons__subhead {
    font-family: var(--font-sans);
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0 0 0.75rem;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }
  .proscons__col--pros .proscons__subhead { color: var(--color-success); }
  .proscons__col--cons .proscons__subhead { color: var(--color-danger); }

  .proscons__dot {
    width: 8px;
    height: 8px;
    border-radius: 999px;
    background: currentColor;
    display: inline-block;
  }

  .proscons__col ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }
  .proscons__col li {
    display: flex;
    gap: 0.55rem;
    align-items: flex-start;
    color: var(--color-ink-dim);
    font-size: 0.95rem;
    line-height: 1.5;
    margin: 0;
  }
  .proscons__icon { flex: 0 0 auto; margin-top: 0.2rem; }
  .proscons__col--pros .proscons__icon { color: var(--color-success); }
  .proscons__col--cons .proscons__icon { color: var(--color-danger); }
</style>

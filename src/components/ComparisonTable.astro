---
/**
 * ComparisonTable.astro — Side-by-side axis comparison for 2–4 tools.
 * Rows mix scalar rows (price, platforms, trial) with 1–10 score bars.
 * AdRecon column gets a subtle accent background.
 */
import { getCompetitor, scoreSeverity } from '@/lib/competitors';
import type { CompetitorSlug } from '@/lib/constants';
import { DATA_AS_OF } from '@/lib/constants';
import ToolLogo from './ToolLogo.astro';

export interface Props {
  slugs: CompetitorSlug[];
  axes?: string[];
  heading?: string;
}

type Competitor = Awaited<ReturnType<typeof getCompetitor>>;

const DEFAULT_AXES = [
  'startingPrice',
  'freeTrial',
  'platforms',
  'landingPages',
  'offers',
  'coverage',
  'dataFreshness',
  'ux',
  'affiliateFocus',
  'search',
];

const SCORE_AXES = new Set([
  'coverage',
  'dataFreshness',
  'price',
  'ux',
  'landingPages',
  'offers',
  'affiliateFocus',
  'search',
]);

const AXIS_LABEL: Record<string, string> = {
  startingPrice: 'Starting price',
  freeTrial: 'Free trial',
  freeTier: 'Free tier',
  platforms: 'Platforms',
  claimedAdCount: 'Claimed ad count',
  historyDepth: 'History depth',
  updateCadence: 'Update cadence',
  refundPolicy: 'Refund policy',
  coverage: 'Coverage',
  dataFreshness: 'Data freshness',
  price: 'Price / value',
  ux: 'UX',
  landingPages: 'Landing pages',
  offers: 'Offer intelligence',
  affiliateFocus: 'Affiliate focus',
  search: 'Search & filters',
  standoutFeature: 'Standout feature',
};

const { slugs, axes = DEFAULT_AXES, heading = 'Head-to-head comparison' } = Astro.props;

const competitors: Competitor[] = await Promise.all(slugs.map((s) => getCompetitor(s)));

const formatPrice = (monthly: number | null, currency: string): string => {
  if (monthly === null) return 'Custom';
  if (monthly === 0) return 'Free';
  const symbol = currency === 'EUR' ? '€' : currency === 'GBP' ? '£' : '$';
  return `${symbol}${monthly.toLocaleString('en-US')}/mo`;
};

type CellKind = 'text' | 'bool' | 'score' | 'list';
type Cell = { kind: CellKind; value: string | boolean | number | string[] };

const getCell = (c: Competitor, axis: string): Cell => {
  const d = c.data;

  if (SCORE_AXES.has(axis)) {
    return { kind: 'score', value: (d.scores as unknown as Record<string, number>)[axis] ?? 0 };
  }
  switch (axis) {
    case 'startingPrice':
      return { kind: 'text', value: formatPrice(d.pricing.startingMonthly, d.pricing.currency) };
    case 'freeTrial':
      return { kind: 'bool', value: Boolean(d.pricing.freeTrial && d.pricing.freeTrial.days > 0) };
    case 'freeTier':
      return { kind: 'bool', value: d.pricing.freeTier };
    case 'platforms':
      return { kind: 'list', value: d.platforms };
    case 'claimedAdCount':
      return { kind: 'text', value: d.coverage.claimedAdCount ?? '—' };
    case 'historyDepth':
      return { kind: 'text', value: d.coverage.historyDepth ?? '—' };
    case 'updateCadence':
      return { kind: 'text', value: d.coverage.updateCadence ?? '—' };
    case 'refundPolicy':
      return { kind: 'text', value: d.pricing.refundPolicy ?? '—' };
    case 'standoutFeature':
      return { kind: 'text', value: d.standoutFeature };
    default:
      return { kind: 'text', value: '—' };
  }
};

const adreconIndex = competitors.findIndex((c) => c.data.slug === 'adrecon');
---

<section class="compare card" aria-label={heading}>
  <header class="compare__header">
    <p class="label-mono">Comparison</p>
    <h3 class="compare__title">{heading}</h3>
    <p class="compare__note">Data as of {DATA_AS_OF}. Competitor claims are cited as claims, not facts.</p>
  </header>

  <div class="compare__scroll">
    <table class="compare__table">
      <thead>
        <tr>
          <th scope="col" class="compare__rowhead">Dimension</th>
          {competitors.map((c, i) => (
            <th
              scope="col"
              class:list={['compare__colhead', i === adreconIndex ? 'is-adrecon' : null]}
            >
              <div class="compare__toolhead">
                <ToolLogo slug={c.data.slug as CompetitorSlug} size="sm" />
                <span class="compare__toolname">{c.data.name}</span>
              </div>
            </th>
          ))}
        </tr>
      </thead>
      <tbody>
        {axes.map((axis) => (
          <tr>
            <th scope="row" class="compare__rowhead">{AXIS_LABEL[axis] ?? axis}</th>
            {competitors.map((c, i) => {
              const cell = getCell(c, axis);
              const isAdRecon = i === adreconIndex;
              return (
                <td class:list={['compare__cell', isAdRecon ? 'is-adrecon' : null]}>
                  {cell.kind === 'score' && (() => {
                    const v = cell.value as number;
                    const pct = Math.max(0, Math.min(100, (v / 10) * 100));
                    const sev = scoreSeverity(v);
                    return (
                      <div class="compare__score">
                        <div class:list={['compare__bar', `sev-${sev}`]} role="progressbar" aria-valuenow={v} aria-valuemin={1} aria-valuemax={10}>
                          <span class="compare__bar-fill" style={`width: ${pct}%;`}></span>
                        </div>
                        <span class="compare__score-num">{v.toFixed(1)}</span>
                      </div>
                    );
                  })()}
                  {cell.kind === 'bool' && (
                    cell.value ? (
                      <span class="compare__bool compare__bool--yes" aria-label="Yes">
                        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                          <path d="M3 8.5L6.5 12L13 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                        Yes
                      </span>
                    ) : (
                      <span class="compare__bool compare__bool--no" aria-label="No">
                        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                          <path d="M4 4L12 12M12 4L4 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                        No
                      </span>
                    )
                  )}
                  {cell.kind === 'text' && (
                    <span class="compare__text">{cell.value as string}</span>
                  )}
                  {cell.kind === 'list' && (
                    <span class="compare__text">{(cell.value as string[]).join(', ')}</span>
                  )}
                </td>
              );
            })}
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</section>

<style>
  .compare {
    padding: 1.5rem;
  }
  .compare__header {
    margin-bottom: 1rem;
  }
  .compare__title {
    font-family: var(--font-sans);
    font-size: 1.25rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0.2rem 0 0.3rem;
  }
  .compare__note {
    font-size: 0.82rem;
    color: var(--color-ink-subtle);
    margin: 0;
  }

  .compare__scroll {
    overflow-x: auto;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-md);
    background: var(--color-surface-2);
  }

  .compare__table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.92rem;
    min-width: 40rem;
  }

  .compare__table thead th {
    position: sticky;
    top: 0;
    background: var(--color-surface-3);
    z-index: 1;
    border-bottom: 1px solid var(--color-line);
  }

  .compare__rowhead {
    text-align: left;
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 0.82rem;
    color: var(--color-ink-mute);
    padding: 0.75rem 0.9rem;
    background: var(--color-surface-3);
    white-space: nowrap;
  }
  tbody .compare__rowhead {
    position: sticky;
    left: 0;
    z-index: 0;
    border-bottom: 1px solid var(--color-line);
    background: var(--color-surface-2);
  }

  .compare__colhead {
    padding: 0.75rem 0.9rem;
    text-align: left;
    font-weight: 600;
  }
  .compare__colhead.is-adrecon,
  .compare__cell.is-adrecon {
    background: color-mix(in oklch, var(--color-gold-soft) 65%, transparent);
  }
  .compare__colhead.is-adrecon { background: color-mix(in oklch, var(--color-gold-soft) 85%, var(--color-surface-3)); }

  .compare__toolhead {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }
  .compare__toolname {
    font-size: 0.92rem;
    color: var(--color-type);
  }

  .compare__cell {
    padding: 0.65rem 0.9rem;
    border-bottom: 1px solid var(--color-line);
    color: var(--color-ink-dim);
    vertical-align: middle;
  }
  tbody tr:last-child .compare__cell,
  tbody tr:last-child .compare__rowhead {
    border-bottom: 0;
  }

  .compare__text {
    color: var(--color-type);
    font-size: 0.9rem;
  }

  .compare__bool {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .compare__bool--yes { color: var(--color-success); }
  .compare__bool--no { color: var(--color-danger); }

  .compare__score {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    min-width: 8rem;
  }
  .compare__bar {
    flex: 1;
    height: 7px;
    background: var(--color-surface);
    border-radius: 999px;
    overflow: hidden;
  }
  .compare__bar-fill {
    display: block;
    height: 100%;
    border-radius: 999px;
  }
  .sev-high .compare__bar-fill { background: var(--color-success); }
  .sev-med .compare__bar-fill { background: var(--color-warning); }
  .sev-low .compare__bar-fill { background: var(--color-danger); }

  .compare__score-num {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--color-type);
    font-weight: 600;
    font-variant-numeric: tabular-nums;
    min-width: 2.25rem;
    text-align: right;
  }
</style>

---
/**
 * Nav — clean editorial top bar. Light theme, minimal chrome, one wordmark,
 * and a link to editorial standards.
 */
import { routes, SITE_URL } from "@/lib/constants";

const links = [
  { href: routes.hub(), label: "Ad Spy Tools" },
  { href: "/guides/", label: "Guides" },
  { href: routes.methodology(), label: "Methodology" },
  { href: routes.about(), label: "About" },
];

const { pathname } = Astro.url ?? new URL("/", SITE_URL);
const isActive = (href: string) =>
  href === "/" ? pathname === "/" : pathname.startsWith(href);
---

<header class="site-nav">
  <div class="container-wide site-nav__inner">
    <a class="site-nav__logo" href="/" aria-label="AffiliateTools.co home">
      <svg
        width="24"
        height="24"
        viewBox="0 0 24 24"
        aria-hidden="true"
        class="site-nav__logo-icon"
      >
        <rect
          x="2"
          y="2"
          width="20"
          height="20"
          rx="5"
          fill="currentColor"
          opacity="0.12"></rect>
        <path
          d="M7 15 L12 6 L17 15 M9 12 H15"
          stroke="currentColor"
          stroke-width="1.8"
          stroke-linecap="round"
          stroke-linejoin="round"
          fill="none"></path>
      </svg>
      <span class="site-nav__logo-name"
        >AffiliateTools<span class="site-nav__logo-tld">.co</span></span
      >
    </a>

    <nav class="site-nav__links" aria-label="Primary">
      {
        links.map((l) => (
          <a
            href={l.href}
            class:list={[
              "site-nav__link",
              { "site-nav__link--active": isActive(l.href) },
            ]}
          >
            {l.label}
          </a>
        ))
      }
    </nav>

    <div class="site-nav__right">
      <a class="btn btn-secondary btn-sm" href={routes.disclosure()}>
        Standards
      </a>
    </div>

    <details class="site-nav__mobile">
      <summary aria-label="Open navigation menu">
        <span class="site-nav__hamburger" aria-hidden="true">
          <span></span>
          <span></span>
          <span></span>
        </span>
      </summary>
      <div class="site-nav__drawer">
        {
          links.map((l) => (
            <a href={l.href} class="site-nav__drawer-link">
              {l.label}
            </a>
          ))
        }
        <a
          class="btn btn-secondary site-nav__drawer-cta"
          href={routes.disclosure()}
        >
          Editorial standards
        </a>
      </div>
    </details>
  </div>
</header>

<style>
  .site-nav {
    position: sticky;
    top: 0;
    z-index: 40;
    background: color-mix(in oklch, var(--color-canvas) 92%, transparent);
    border-bottom: 1px solid var(--color-line);
    backdrop-filter: blur(16px) saturate(1.2);
    -webkit-backdrop-filter: blur(16px) saturate(1.2);
  }
  .site-nav__inner {
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }
  .site-nav__logo {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    color: var(--color-accent);
    font-weight: 700;
    font-size: 1rem;
    letter-spacing: -0.02em;
  }
  .site-nav__logo:hover {
    text-decoration: none;
    color: var(--color-accent-hover);
  }
  .site-nav__logo-icon {
    flex: 0 0 auto;
  }
  .site-nav__logo-name {
    color: var(--color-type);
    font-weight: 700;
  }
  .site-nav__logo-tld {
    color: var(--color-type-mute);
    font-weight: 500;
  }

  .site-nav__links {
    display: none;
    align-items: center;
    gap: 2rem;
    flex: 1;
    justify-content: center;
  }
  .site-nav__link {
    font-size: 0.9rem;
    color: var(--color-type-dim);
    text-decoration: none;
    font-weight: 500;
    letter-spacing: -0.005em;
    transition: color 0.15s ease;
  }
  .site-nav__link:hover {
    color: var(--color-accent);
    text-decoration: none;
  }
  .site-nav__link--active {
    color: var(--color-accent);
    font-weight: 600;
  }

  .site-nav__right {
    display: none;
    align-items: center;
    gap: 0.75rem;
  }

  .site-nav__mobile {
    position: relative;
    display: block;
  }
  .site-nav__mobile > summary {
    list-style: none;
    cursor: pointer;
    padding: 0.5rem;
    border-radius: var(--radius-md);
    border: 1px solid var(--color-line);
    background: var(--color-canvas);
  }
  .site-nav__mobile > summary::-webkit-details-marker {
    display: none;
  }
  .site-nav__hamburger {
    display: inline-flex;
    flex-direction: column;
    gap: 4px;
    width: 18px;
  }
  .site-nav__hamburger > span {
    display: block;
    height: 1.5px;
    background: var(--color-type);
    border-radius: 2px;
    transition:
      transform 0.15s ease,
      opacity 0.15s ease;
  }
  .site-nav__mobile[open] > summary .site-nav__hamburger > span:nth-child(1) {
    transform: translateY(5.5px) rotate(45deg);
  }
  .site-nav__mobile[open] > summary .site-nav__hamburger > span:nth-child(2) {
    opacity: 0;
  }
  .site-nav__mobile[open] > summary .site-nav__hamburger > span:nth-child(3) {
    transform: translateY(-5.5px) rotate(-45deg);
  }
  .site-nav__drawer {
    position: absolute;
    top: calc(100% + 0.6rem);
    right: 0;
    min-width: 240px;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 0.75rem;
    background: var(--color-canvas);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
  }
  .site-nav__drawer-link {
    padding: 0.65rem 0.75rem;
    color: var(--color-type-dim);
    text-decoration: none;
    border-radius: var(--radius-sm);
    font-weight: 500;
  }
  .site-nav__drawer-link:hover {
    background: var(--color-surface);
    color: var(--color-accent);
    text-decoration: none;
  }
  .site-nav__drawer-cta {
    margin-top: 0.4rem;
  }

  @media (min-width: 900px) {
    .site-nav__links {
      display: flex;
    }
    .site-nav__right {
      display: flex;
    }
    .site-nav__mobile {
      display: none;
    }
  }
</style>

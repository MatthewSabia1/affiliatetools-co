---
import BaseLayout from './BaseLayout.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import Hero from '@/components/Hero.astro';
import AuthorshipBox from '@/components/AuthorshipBox.astro';
import CTA from '@/components/CTA.astro';
import TOC from '@/components/TOC.astro';
import type { MarkdownHeading } from 'astro';
import { absoluteUrl } from '@/lib/constants';
import {
  breadcrumbList,
  articleJsonLd,
  faqPage,
  organizationJsonLd,
  type JsonLd,
} from '@/lib/schema';

export interface Props {
  title: string;
  description: string;
  canonical: string;
  publishDate: string;
  updatedDate: string;
  heroEyebrow?: string;
  faq?: Array<{ q: string; a: string }>;
  campaignSlug: string;
  headings: MarkdownHeading[];
}

const {
  title,
  description,
  canonical,
  publishDate,
  updatedDate,
  heroEyebrow = 'Guide',
  faq,
  campaignSlug,
  headings,
} = Astro.props;

const crumbItems = [
  { name: 'Home', href: '/' },
  { name: 'Guides', href: '/guides/' },
  { name: title },
];

const pageUrl = absoluteUrl(canonical);

const jsonLd: JsonLd[] = [
  breadcrumbList([
    { name: 'Home', path: '/' },
    { name: 'Guides', path: '/guides/' },
    { name: title, path: canonical },
  ]),
  articleJsonLd({
    pageUrl,
    headline: title,
    description,
    datePublished: publishDate,
    dateModified: updatedDate,
  }),
  organizationJsonLd(),
];

if (faq && faq.length > 0) {
  jsonLd.push(faqPage(faq));
}
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  jsonLd={jsonLd}
  pageType="article"
>
  <div class="container-wide" style="padding-top: 1.5rem;">
    <Breadcrumb items={crumbItems} />
  </div>

  <Hero
    eyebrow={heroEyebrow}
    title={title}
    sub={description}
    updatedDate={updatedDate}
  />

  <article class="container-wide guide-article">
    <div class="guide-grid">
      <div class="guide-main">
        <AuthorshipBox publishDate={publishDate} updatedDate={updatedDate} />
        <div class="prose">
          <slot />
        </div>
        <div class="guide-footer-cta">
          <CTA variant="footer" campaign={campaignSlug} medium="guide" label="Try AdRecon" />
        </div>
      </div>
      <aside class="guide-sidebar">
        <div class="sticky-sidebar guide-sidebar-inner">
          <TOC headings={headings} />
        </div>
      </aside>
    </div>
  </article>

  <style>
    .guide-article {
      padding-block: 2.5rem 4rem;
    }
    .guide-grid {
      display: grid;
      grid-template-columns: minmax(0, 1fr);
      gap: 3rem;
    }
    @media (min-width: 1024px) {
      .guide-grid {
        grid-template-columns: minmax(0, 1fr) 280px;
      }
    }
    .guide-sidebar-inner {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }
    .guide-footer-cta {
      margin-top: 3rem;
    }
  </style>
</BaseLayout>

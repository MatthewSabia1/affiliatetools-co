---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/Hero.astro';
import CTA from '@/components/CTA.astro';
import ToolLogo from '@/components/ToolLogo.astro';
import Rating from '@/components/Rating.astro';
import FAQ from '@/components/FAQ.astro';
import ScoringMethodology from '@/components/ScoringMethodology.astro';
import WinnersGrid from '@/components/WinnersGrid.astro';
import { getCompetitorsInDisplayOrder, overallScore } from '@/lib/competitors';
import { routes, SITE_URL, SITE_DESCRIPTION, VERSUS_SLUGS } from '@/lib/constants';
import { collectionPageJsonLd, breadcrumbList, faqPage } from '@/lib/schema';

const competitors = await getCompetitorsInDisplayOrder();

const flagshipListicles = [
  { slug: 'best-ad-spy-tools-2026', title: 'Best Ad Spy Tools of 2026', blurb: 'Our flagship ranking — tested across 8 dimensions.' },
  { slug: 'best-ad-spy-tools-for-affiliate-marketers', title: 'Best Ad Spy Tools for Affiliate Marketers', blurb: 'Affiliate-specific picks with CPA-network classification in mind.' },
  { slug: 'best-ad-spy-tools-for-facebook-ads', title: 'Best Ad Spy Tools for Facebook Ads', blurb: 'Meta-focused picks for Facebook & Instagram research.' },
  { slug: 'adspy-alternatives', title: 'AdSpy Alternatives', blurb: 'Better-value alternatives to the $149/mo incumbent.' },
  { slug: 'best-free-ad-spy-tools', title: 'Best Free Ad Spy Tools', blurb: 'What actually works at $0 — and when to upgrade.' },
  { slug: 'best-ad-spy-tools-for-clickbank', title: 'Best Ad Spy Tools for ClickBank', blurb: 'Tools that auto-detect ClickBank creatives vs those that don\'t.' },
];

const faqs = [
  { q: 'Who operates AffiliateTools.co?', a: 'AffiliateTools.co is operated by the AdRecon team — AdRecon is an ad intelligence platform for affiliate marketers on Meta. AdRecon is a direct competitor to most of the tools we review. We disclose this openly on every page and compensate for it by publishing our methodology, stating competitor strengths before our own, and admitting AdRecon\'s limitations (Meta-only coverage, no AI features, premium pricing).' },
  { q: 'What category is "affiliate tools"?', a: 'The affiliate marketer\'s software stack includes ad spy tools (for researching what\'s working), landing page builders, affiliate tracking platforms, offer networks, email marketing tools, and creative research tools. Our v1 coverage focuses on ad spy tools; we plan to expand into landing page builders, tracking platforms, and email tools over time.' },
  { q: 'Are these reviews paid placements?', a: 'No. We do not accept paid placement or sponsored rankings. AdRecon pays for the infrastructure hosting this site, but no tool on this site paid to be included or to improve its ranking. See our methodology for the ranking criteria we actually use.' },
  { q: 'How often are reviews updated?', a: 'We refresh pricing quarterly and rerun full feature audits annually. Every page shows the "Updated" date in the hero. If you spot an outdated fact, please email hello@affiliatetools.co.' },
  { q: 'Does AffiliateTools.co cover tools beyond ad spy?', a: 'Not yet in v1. The current scope is ad spy / ad intelligence tools for affiliate marketers on Meta. Future expansion will cover email marketing, affiliate networks, landing page builders, and tracking platforms.' },
];

const canonical = '/';
const title = 'AffiliateTools.co — Honest Reviews of Ad Spy Tools & Affiliate Software';
const description = SITE_DESCRIPTION;

const jsonLd = [
  breadcrumbList([{ name: 'Home', path: '/' }]),
  collectionPageJsonLd({
    pageUrl: `${SITE_URL}/`,
    name: 'AffiliateTools.co',
    description,
    hasPart: competitors.slice(0, 7).map((c) => ({
      url: `${SITE_URL}${routes.review(c.data.slug as any)}`,
      name: `${c.data.name} Review`,
      description: c.data.cardBlurb,
    })),
  }),
  faqPage(faqs),
];

const DIM_NAMES: Record<string, string> = {
  coverage: 'Coverage',
  dataFreshness: 'Freshness',
  price: 'Value',
  ux: 'UX',
  landingPages: 'Landing pages',
  offers: 'Offers',
  affiliateFocus: 'Affiliate fit',
  search: 'Search',
};

function startLabelFor(c: typeof competitors[number]['data']): string {
  if (c.pricing.startingMonthly === null) {
    return c.slug === 'adrecon' ? '$299 lifetime' : 'Custom pricing';
  }
  if (c.pricing.startingMonthly === 0) return 'Free tier';
  return `From $${c.pricing.startingMonthly}/mo`;
}

function topThreeDims(scores: Record<string, number>): Array<[string, number]> {
  return Object.entries(scores).sort((a, b) => b[1] - a[1]).slice(0, 3);
}

function firstBestFor(c: typeof competitors[number]['data']): string | null {
  return c.bestFor?.[0] ?? null;
}

function shortenBestFor(s: string): string {
  // Trim to a punchy 5-6 word chip. Break at common delimiters first, then fall back to word count.
  const cut = s.split(/[—–,:;(]/)[0]?.trim() ?? s;
  const words = cut.split(/\s+/);
  if (words.length <= 6) return cut;
  return words.slice(0, 6).join(' ') + '…';
}

// Pre-compute card data for all competitors.
const competitorCards = competitors.map((c, idx) => {
  const scoresRec: Record<string, number> = c.data.scores as unknown as Record<string, number>;
  const overall = overallScore(c.data.scores);
  return {
    rank: idx + 1,
    slug: c.data.slug,
    name: c.data.name,
    tagline: c.data.tagline,
    blurb: c.data.cardBlurb,
    startLabel: startLabelFor(c.data),
    overall,
    topDims: topThreeDims(scoresRec),
    bestFor: (c.data.bestFor ?? []).slice(0, 2).map(shortenBestFor),
    standout: c.data.standoutFeature?.trim(),
    href: routes.review(c.data.slug as any),
  };
});

// Sort competitors by overall score for the leaderboard (top 3)
const leaderboard = [...competitorCards].sort((a, b) => b.overall - a.overall).slice(0, 3);

// Directory leaderboard accent classes cycle for visual rhythm
const leaderAccents = ['var(--color-accent)', '#1f7a3e', '#b5791f'];

// ---- Matrix table data (full 7 rows × dimensions) ----
type MatrixRow = {
  slug: string;
  name: string;
  tagline: string;
  href: string;
  startLabel: string;
  overall: number;
  scores: Record<string, number>;
  badge?: string;
};

const MATRIX_DIMS: Array<{ key: string; label: string; short: string }> = [
  { key: 'coverage', label: 'Coverage', short: 'Cov' },
  { key: 'dataFreshness', label: 'Freshness', short: 'Fresh' },
  { key: 'price', label: 'Value', short: 'Val' },
  { key: 'ux', label: 'UX', short: 'UX' },
  { key: 'affiliateFocus', label: 'Affiliate', short: 'Aff' },
];

const matrixRows: MatrixRow[] = competitors
  .map((c) => {
    const scoresRec: Record<string, number> = c.data.scores as unknown as Record<string, number>;
    return {
      slug: c.data.slug,
      name: c.data.name,
      tagline: c.data.tagline,
      href: routes.review(c.data.slug as any),
      startLabel: startLabelFor(c.data),
      overall: overallScore(c.data.scores),
      scores: scoresRec,
    };
  })
  .sort((a, b) => b.overall - a.overall)
  .map((row, i) => ({
    ...row,
    badge: i === 0 ? 'Editor\'s pick' : (row.overall >= 7.5 ? 'Recommended' : undefined),
  }));

// Pullquote data
const pullquote = {
  body: 'Most review sites chase traffic. We chase accuracy. We own one of the tools we review — so we over-correct toward honesty, because the alternative is losing the only thing that makes this directory worth reading.',
  attribution: 'Matthew Sabia',
  role: 'Founder · AdRecon',
};
---

<BaseLayout title={title} description={description} canonical={canonical} jsonLd={jsonLd} pageType="website">
  <Hero
    eyebrow="Independent review hub · Vol. 01 · April 2026"
    title="The software affiliate marketers actually run — reviewed honestly."
    titleHtml={`The software affiliate marketers actually run — <em>reviewed honestly.</em>`}
    sub="Hands-on reviews of ad spy tools, landing-page builders, affiliate networks, and the software that runs real affiliate campaigns. Operated by the AdRecon team — we disclose that openly."
    primaryCta={{ href: '/ad-spy-tools/', label: 'Browse ad spy tools' }}
    secondaryCta={{ href: '/methodology/', label: 'How we test' }}
    withStats={true}
  >
    <div class="hero-filters" slot="filters">
      <span class="hero-filters__key">Filter by use case</span>
      <div class="hero-filters__chips">
        <a href="/ad-spy-tools/adrecon-review/" class="hero-filters__chip">Meta affiliates</a>
        <a href="/ad-spy-tools/pipiads-review/" class="hero-filters__chip">TikTok</a>
        <a href="/ad-spy-tools/bigspy-review/" class="hero-filters__chip">Free tier</a>
        <a href="/ad-spy-tools/foreplay-review/" class="hero-filters__chip">Agency workflow</a>
        <a href="/ad-spy-tools/minea-review/" class="hero-filters__chip">Dropshipping</a>
        <a href="/ad-spy-tools/best-ad-spy-tools-for-clickbank/" class="hero-filters__chip">ClickBank</a>
      </div>
    </div>
  </Hero>

  {/* ========== TRUST STRIP ========== */}
  <section class="trust-strip" aria-label="At-a-glance editorial facts">
    <div class="container-wide trust-strip__inner">
      <div class="trust-kpi">
        <span class="trust-kpi__val">7</span>
        <span class="trust-kpi__key">Ad spy tools reviewed hands-on</span>
      </div>
      <div class="trust-kpi">
        <span class="trust-kpi__val">300K+</span>
        <span class="trust-kpi__key">Ad records analyzed on Meta</span>
      </div>
      <div class="trust-kpi">
        <span class="trust-kpi__val">8</span>
        <span class="trust-kpi__key">Scoring dimensions, individually weighted</span>
      </div>
      <div class="trust-kpi">
        <span class="trust-kpi__val">0</span>
        <span class="trust-kpi__key">Paid placements, ever</span>
      </div>
      <div class="trust-kpi trust-kpi--cta">
        <a href="/methodology/" class="trust-kpi__link">
          Read methodology
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M3 6h6m0 0L6 3m3 3L6 9" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
    </div>
  </section>

  {/* ========== INTRO ========== */}
  <section class="container-wide section-intro">
    <div class="intro-grid">
      <div class="intro-prose">
        <p class="kicker"><span class="kicker__num">00</span> Editorial note</p>
        <p class="intro-lead">
          Affiliate marketers buy their tools differently than brand marketers. You need specificity —
          tools that understand ClickBank creatives, that track days-running instead of impressions,
          that capture landing pages before they get pulled. Most review sites don't know the difference.
        </p>
        <p>
          AffiliateTools.co is built by operators for operators. We review ad spy tools, landing-page
          platforms, affiliate networks, tracking stacks, and the broader software set that actually
          runs affiliate campaigns. Every review admits where a competitor wins before we pitch our own
          tool. Every claim is dated. Every price cites the source.
        </p>
      </div>
      <aside class="intro-aside">
        <h3 class="intro-aside__title">Quick picks</h3>
        <ul class="quick-picks">
          <li><span class="qp-tag">Meta affiliates</span><a href="/ad-spy-tools/adrecon-review/">AdRecon</a></li>
          <li><span class="qp-tag">Boolean search</span><a href="/ad-spy-tools/adspy-review/">AdSpy</a></li>
          <li><span class="qp-tag">Free tier</span><a href="/ad-spy-tools/bigspy-review/">BigSpy</a></li>
          <li><span class="qp-tag">TikTok</span><a href="/ad-spy-tools/pipiads-review/">PiPiADS</a></li>
          <li><span class="qp-tag">Dropshipping</span><a href="/ad-spy-tools/minea-review/">Minea</a></li>
          <li><span class="qp-tag">Agency workflow</span><a href="/ad-spy-tools/foreplay-review/">Foreplay</a></li>
        </ul>
      </aside>
    </div>
  </section>

  {/* ========== LEADERBOARD (top 3) ========== */}
  <section class="container-wide section-block">
    <header class="section-head">
      <p class="kicker"><span class="kicker__num">01</span> Leaderboard</p>
      <div class="section-head__titles">
        <h2>Top 3 ad spy tools this quarter</h2>
        <p class="section-head__sub">Ranked by aggregate score across 8 weighted dimensions.<br/>See the <a href="/methodology/">full methodology</a> or jump to any <a href="#featured-reviews">review below</a>.</p>
      </div>
    </header>
    <ol class="board">
      {leaderboard.map((card, i) => (
        <li class="board__row" style={`--accent: ${leaderAccents[i]};`}>
          <a href={card.href} class="board__link">
            <span class="board__rank">
              <span class="board__rank-num">0{i + 1}</span>
              <span class="board__rank-bar" aria-hidden="true"></span>
            </span>
            <span class="board__logo">
              <ToolLogo slug={card.slug as any} size="md" surface="none" />
            </span>
            <span class="board__title">
              <span class="board__name">{card.name}</span>
              <span class="board__tag">{card.tagline}</span>
            </span>
            <span class="board__score">
              <Rating value={card.overall} size="md" theme="light" />
            </span>
            <span class="board__price">
              <span class="board__price-val">{card.startLabel}</span>
              <span class="board__price-key">starting</span>
            </span>
            <span class="board__cta" aria-hidden="true">
              Open review
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M3 7h8m0 0L7 3m4 4l-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
          </a>
        </li>
      ))}
    </ol>
  </section>

  {/* ========== CATEGORIES ========== */}
  <section class="container-wide section-block">
    <header class="section-head section-head--compact">
      <p class="kicker"><span class="kicker__num">02</span> Categories</p>
      <div class="section-head__titles">
        <h2>What we cover</h2>
        <p class="section-head__sub">Starting with ad spy — expanding into the wider affiliate software stack.</p>
      </div>
    </header>
    <div class="cat-grid">
      <a class="cat-card cat-card--live" href="/ad-spy-tools/">
        <div class="cat-card__head">
          <div class="cat-card__icon">⬢</div>
          <span class="cat-card__pill cat-card__pill--live">Live</span>
        </div>
        <h3>Ad Spy Tools</h3>
        <p>7 reviews, 21 head-to-heads, and ranked listicles for affiliate marketers, agencies, and performance buyers.</p>
        <span class="cat-card__meta">7 reviews · 6 comparisons · 6 rankings</span>
      </a>
      <div class="cat-card cat-card--soon">
        <div class="cat-card__head">
          <div class="cat-card__icon">◇</div>
          <span class="cat-card__pill">Soon</span>
        </div>
        <h3>Landing Page Builders</h3>
        <p>ClickFunnels, Leadpages, Unbounce, Systeme.io — reviewed for affiliate marketers specifically.</p>
        <span class="cat-card__meta">Q3 2026 · 6+ reviews planned</span>
      </div>
      <div class="cat-card cat-card--soon">
        <div class="cat-card__head">
          <div class="cat-card__icon">⌗</div>
          <span class="cat-card__pill">Soon</span>
        </div>
        <h3>Tracking & Analytics</h3>
        <p>Voluum, RedTrack, Binom, FunnelFlux, Everflow — what real affiliates actually run in production.</p>
        <span class="cat-card__meta">Q4 2026 · 5+ reviews planned</span>
      </div>
      <div class="cat-card cat-card--soon">
        <div class="cat-card__head">
          <div class="cat-card__icon">✉</div>
          <span class="cat-card__pill">Soon</span>
        </div>
        <h3>Email Marketing</h3>
        <p>Beehiiv, ConvertKit, Klaviyo — scored against affiliate use cases specifically, not brand marketing.</p>
        <span class="cat-card__meta">2027 · 4+ reviews planned</span>
      </div>
    </div>
  </section>

  {/* ========== FEATURED REVIEWS ========== */}
  {/* ========== FULL RANKING MATRIX (dense comparison table) ========== */}
  <section id="featured-reviews" class="container-wide section-block">
    <header class="section-head">
      <p class="kicker"><span class="kicker__num">03</span> The board</p>
      <div class="section-head__titles">
        <h2>The full ranking, <em>at a glance</em></h2>
        <p class="section-head__sub">All 7 ad spy tools, scored on 8 dimensions and sorted by aggregate. Tap any row for the full review.</p>
      </div>
    </header>

    <div class="matrix">
      <div class="matrix__head" role="row">
        <span class="matrix__h matrix__h--rank">#</span>
        <span class="matrix__h matrix__h--tool">Tool</span>
        <span class="matrix__h matrix__h--score">Overall</span>
        {MATRIX_DIMS.map((d) => (
          <span class="matrix__h matrix__h--dim" title={d.label}>
            <span class="matrix__h-full">{d.label}</span>
            <span class="matrix__h-short">{d.short}</span>
          </span>
        ))}
        <span class="matrix__h matrix__h--price">Starting</span>
        <span class="matrix__h matrix__h--action" aria-hidden="true"></span>
      </div>

      {matrixRows.map((row, i) => (
        <a class="matrix__row" href={row.href} role="row">
          <span class="matrix__c matrix__c--rank">
            <span class="matrix__rank-n">0{i + 1}</span>
          </span>

          <span class="matrix__c matrix__c--tool">
            <span class="matrix__logo">
              <ToolLogo slug={row.slug as any} size="sm" surface="none" />
            </span>
            <span class="matrix__namewrap">
              <span class="matrix__name">
                {row.name}
                {row.badge && <span class={`matrix__badge matrix__badge--${i === 0 ? 'pick' : 'rec'}`}>{row.badge}</span>}
              </span>
              <span class="matrix__tagline">{row.tagline}</span>
            </span>
          </span>

          <span class="matrix__c matrix__c--score">
            <Rating value={row.overall} size="sm" theme="light" />
          </span>

          {MATRIX_DIMS.map((d) => {
            const v = row.scores[d.key] ?? 0;
            const sev = v >= 7.5 ? 'high' : v >= 5 ? 'med' : 'low';
            return (
              <span class={`matrix__c matrix__c--dim matrix__dim matrix__dim--${sev}`}>
                <span class="matrix__dim-val">{v.toFixed(1)}</span>
                <span class="matrix__dim-track" aria-hidden="true">
                  <span class="matrix__dim-fill" style={`width: ${v * 10}%;`}></span>
                </span>
              </span>
            );
          })}

          <span class="matrix__c matrix__c--price">
            <span class="matrix__price-v">{row.startLabel}</span>
          </span>

          <span class="matrix__c matrix__c--action" aria-hidden="true">
            <span class="matrix__arrow">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M3 7h8m0 0L7 3m4 4l-4 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
          </span>
        </a>
      ))}

      <div class="matrix__foot">
        <span class="matrix__foot-note">Full methodology — <a href="/methodology/">how we weight and score</a></span>
        <a class="matrix__foot-cta" href="/ad-spy-tools/">See category hub →</a>
      </div>
    </div>
  </section>

  {/* ========== WINNERS GRID (scatter quadrant chart) ========== */}
  <section class="container-wide section-block">
    <WinnersGrid />
  </section>

  {/* ========== EDITORIAL NOTE BAND ========== */}
  <section class="container-wide section-block ednote-wrap">
    <figure class="ednote">
      <div class="ednote__label-row">
        <span class="ednote__label">Editor's note</span>
        <span class="ednote__rule" aria-hidden="true"></span>
        <span class="ednote__meta">Vol. 01 · April 2026</span>
      </div>
      <blockquote class="ednote__body">
        {pullquote.body}
      </blockquote>
      <figcaption class="ednote__sig">
        <span class="ednote__sig-dash" aria-hidden="true"></span>
        <span class="ednote__sig-name">{pullquote.attribution}</span>
        <span class="ednote__sig-role">{pullquote.role}</span>
      </figcaption>
    </figure>
  </section>

  {/* ========== EDITORS BYLINE BAND ========== */}
  <section class="container-wide section-block">
    <div class="editors-band">
      <div class="editors-band__left">
        <p class="kicker"><span class="kicker__num">04</span> Who writes these reviews</p>
        <h2 class="editors-band__title">Operators, not bloggers.</h2>
        <p class="editors-band__body">
          AffiliateTools.co is run by the AdRecon team — people who actually buy ads, build landers, and
          cash affiliate checks. We built AdRecon because we needed better research on our own campaigns.
          We write these reviews because our team reads competitor marketing all day and got tired of
          nobody saying when the emperor had no clothes.
        </p>
        <ul class="editors-band__list">
          <li><strong>10+ years</strong> combined affiliate operator experience (ClickBank, Digistore24, native arb, DTC).</li>
          <li><strong>Full disclosure</strong> on every page: we own AdRecon, we say so, and we show its weaknesses before its strengths.</li>
          <li><strong>Quarterly refresh</strong> cadence on pricing and feature audits — annual on full methodology.</li>
        </ul>
      </div>
      <aside class="editors-band__right">
        <div class="authors">
          <div class="author">
            <span class="author__avatar" style="--a: #0e2c5f;">MS</span>
            <div class="author__body">
              <span class="author__name">Matthew Sabia</span>
              <span class="author__role">Founder · AdRecon · MediaGlobe</span>
            </div>
          </div>
          <div class="author">
            <span class="author__avatar" style="--a: #1f7a3e;">AT</span>
            <div class="author__body">
              <span class="author__name">AdRecon Team</span>
              <span class="author__role">Editorial · Testing · QA</span>
            </div>
          </div>
        </div>
        <div class="editors-band__badge">
          <span class="editors-band__badge-dot" aria-hidden="true"></span>
          <span>Editorial independence · No paid placement · Conflict disclosed</span>
        </div>
      </aside>
    </div>
  </section>

  <ScoringMethodology />

  {/* ========== HEAD-TO-HEADS ========== */}
  <section class="container-wide section-block">
    <header class="section-head section-head--compact">
      <p class="kicker"><span class="kicker__num">05</span> Comparisons</p>
      <div class="section-head__titles">
        <h2>Popular head-to-heads</h2>
        <p class="section-head__sub">AdRecon vs. every competitor we review — honest, side-by-side, with scorecards.</p>
      </div>
    </header>
    <div class="versus-grid">
      {VERSUS_SLUGS.map((slug) => {
        const c = competitors.find((x) => x.data.slug === slug);
        const tagline = c?.data.tagline ?? '';
        return (
          <a class="versus-card" href={routes.versus(slug)}>
            <span class="versus-card__kick">Head-to-head</span>
            <div class="versus-card__body">
              <span class="versus-card__a">AdRecon</span>
              <span class="versus-card__x" aria-hidden="true">vs</span>
              <span class="versus-card__b">{slug.charAt(0).toUpperCase() + slug.slice(1)}</span>
            </div>
            {tagline && <p class="versus-card__tag">{tagline}</p>}
            <span class="versus-card__cta">Compare →</span>
          </a>
        );
      })}
    </div>
  </section>

  {/* ========== LISTICLES ========== */}
  <section class="container-wide section-block">
    <header class="section-head section-head--compact">
      <p class="kicker"><span class="kicker__num">06</span> Rankings</p>
      <div class="section-head__titles">
        <h2>Best-of rankings</h2>
        <p class="section-head__sub">Ranked listicles across the most-asked queries. All picks sourced from the reviews above.</p>
      </div>
    </header>
    <div class="listicle-grid">
      {flagshipListicles.map((l, i) => (
        <a class="listicle-card" href={`/ad-spy-tools/${l.slug}/`}>
          <span class="listicle-card__num">0{i + 1}</span>

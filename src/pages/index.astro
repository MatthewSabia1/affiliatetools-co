---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Hero from "@/components/Hero.astro";
import ToolLogo from "@/components/ToolLogo.astro";
import Rating from "@/components/Rating.astro";
import FAQ from "@/components/FAQ.astro";
import ScoringMethodology from "@/components/ScoringMethodology.astro";
import { getCollection } from "astro:content";
import { getCompetitorsInDisplayOrder, overallScore } from "@/lib/competitors";
import {
  routes,
  SITE_URL,
  SITE_DESCRIPTION,
  COMPETITOR_SLUGS,
  type CompetitorSlug,
  type ListicleSlug,
} from "@/lib/constants";
import { collectionPageJsonLd, breadcrumbList, faqPage } from "@/lib/schema";
import { formatStartingPrice } from "@/lib/pricing";

const competitors = await getCompetitorsInDisplayOrder();
const guides = (await getCollection("guides", ({ data }) => !data.draft)).sort(
  (a, b) =>
    b.data.updatedDate.localeCompare(a.data.updatedDate) ||
    a.data.title.localeCompare(b.data.title),
);
const versusPages = await getCollection("versus", ({ data }) => !data.draft);
const flagshipListicles = [
  {
    slug: "best-ad-spy-tools-2026",
    title: "Best Ad Spy Tools of 2026",
    blurb: "Our flagship ranking, tested across eight dimensions.",
  },
  {
    slug: "best-ad-spy-tools-for-affiliate-marketers",
    title: "Best Ad Spy Tools for Affiliate Marketers",
    blurb: "Affiliate-specific picks with CPA-network classification in mind.",
  },
  {
    slug: "best-ad-spy-tools-for-facebook-ads",
    title: "Best Ad Spy Tools for Facebook Ads",
    blurb: "Meta-focused picks for Facebook and Instagram research.",
  },
  {
    slug: "adspy-alternatives",
    title: "AdSpy Alternatives",
    blurb: "Better-value alternatives to the $149/month incumbent.",
  },
  {
    slug: "best-free-ad-spy-tools",
    title: "Best Free Ad Spy Tools",
    blurb: "What actually works at $0, and when to upgrade.",
  },
  {
    slug: "best-ad-spy-tools-for-clickbank",
    title: "Best Ad Spy Tools for ClickBank",
    blurb:
      "Tools that auto-detect ClickBank creatives versus those that do not.",
  },
] satisfies Array<{ slug: ListicleSlug; title: string; blurb: string }>;
const featuredComparisonPriority = [
  "adrecon-vs-adspy",
  "adspy-vs-bigspy",
  "adrecon-vs-foreplay",
  "foreplay-vs-minea",
  "adrecon-vs-minea",
  "minea-vs-pipiads",
] as const;
const featuredComparisons = [...versusPages]
  .sort((a, b) => {
    const aIdx = featuredComparisonPriority.indexOf(
      a.slug as (typeof featuredComparisonPriority)[number],
    );
    const bIdx = featuredComparisonPriority.indexOf(
      b.slug as (typeof featuredComparisonPriority)[number],
    );
    const safeA = aIdx === -1 ? Number.MAX_SAFE_INTEGER : aIdx;
    const safeB = bIdx === -1 ? Number.MAX_SAFE_INTEGER : bIdx;
    return safeA - safeB || a.data.title.localeCompare(b.data.title);
  })
  .slice(0, 6)
  .map((entry) => ({
    href: `/ad-spy-tools/${entry.slug}/`,
    title: entry.data.title,
  }));

const liveCoverage = [
  {
    href: routes.hub(),
    icon: "⬢",
    title: "Hands-on reviews",
    body: `${competitors.length} primary tool reviews with scoring, screenshots, pricing notes, and affiliate-fit analysis.`,
    badge: "Live",
  },
  {
    href: routes.listicle("best-ad-spy-tools-2026"),
    icon: "✦",
    title: "Rankings and alternatives",
    body: "Listicles for Facebook ads, affiliate marketers, ClickBank, free tiers, and other bottom-funnel research queries.",
    badge: "Live",
  },
  {
    href: routes.guides(),
    icon: "⌘",
    title: "Research guides",
    body: `${guides.length} educational guides on Meta ad research, landing page teardowns, and affiliate workflow strategy.`,
    badge: "Live",
  },
];

const onDeckCoverage = [
  {
    icon: "◇",
    title: "Broader software stack",
    body: "Landing-page builders, trackers, networks, and email tools are mapped out, but not presented as fully reviewed coverage yet.",
  },
];

const faqs = [
  {
    q: "What does AffiliateTools.co specialize in?",
    a: "AffiliateTools.co specializes in ad spy tools and adjacent affiliate research workflows. The live coverage today is competitor reviews, rankings, head-to-heads, buyer-question pages, and practical guides for affiliate marketers.",
  },
  {
    q: 'What category is "affiliate tools"?',
    a: "The affiliate marketer's software stack includes ad spy tools, landing page builders, trackers, networks, email tools, and creative workflow software. On AffiliateTools.co today, the live editorial coverage is ad spy tools plus practical research guides. Broader stack coverage is planned, but not counted as published review coverage yet.",
  },
  {
    q: "Are these reviews paid placements?",
    a: "No. We do not accept paid placement or sponsored rankings. Inclusion and ranking decisions are editorial and based on the criteria published in our methodology.",
  },
  {
    q: "How often are reviews updated?",
    a: 'We refresh pricing quarterly and rerun full feature audits annually. Every page shows the "Updated" date in the hero. If you spot an outdated fact, please email hello@affiliatetools.co.',
  },
  {
    q: "Does AffiliateTools.co cover tools beyond ad spy?",
    a: "The current published scope is ad spy and ad-intelligence tooling for affiliate marketers, plus educational guides on adjacent workflow topics. We may expand into landing page builders, affiliate networks, trackers, and email platforms later, but those categories are not presented as finished review hubs yet.",
  },
];

const canonical = "/";
const title =
  "AffiliateTools.co — Honest Ad Spy Tool Reviews & Research Guides";
const description = SITE_DESCRIPTION;

function isCompetitorSlug(slug: string): slug is CompetitorSlug {
  return (COMPETITOR_SLUGS as readonly string[]).includes(slug);
}

function toCompetitorSlug(slug: string): CompetitorSlug {
  if (!isCompetitorSlug(slug)) {
    throw new Error(`Unexpected competitor slug on home page: ${slug}`);
  }
  return slug;
}

type ScoreMap = (typeof competitors)[number]["data"]["scores"];
type ScoreAxis = keyof ScoreMap;

const jsonLd = [
  breadcrumbList([{ name: "Home", path: "/" }]),
  collectionPageJsonLd({
    pageUrl: `${SITE_URL}/`,
    name: "AffiliateTools.co",
    description,
    hasPart: competitors.slice(0, 7).map((c) => ({
      url: `${SITE_URL}${routes.review(toCompetitorSlug(c.data.slug))}`,
      name: `${c.data.name} Review`,
      description: c.data.cardBlurb,
    })),
  }),
  faqPage(faqs),
];

const DIM_NAMES: Record<ScoreAxis, string> = {
  coverage: "Coverage",
  dataFreshness: "Freshness",
  price: "Value",
  ux: "UX",
  landingPages: "Landing pages",
  offers: "Offers",
  affiliateFocus: "Affiliate fit",
  search: "Search",
};

function startLabelFor(c: (typeof competitors)[number]["data"]): string {
  return formatStartingPrice(c.pricing, {
    prefixFrom: true,
    freeLabel: "Free tier",
  });
}

function topThreeDims(scores: ScoreMap): Array<[ScoreAxis, number]> {
  return (Object.keys(scores) as ScoreAxis[])
    .map((axis) => [axis, scores[axis]] as [ScoreAxis, number])
    .sort((a, b) => b[1] - a[1])
    .slice(0, 3);
}

const competitorCards = competitors.map((c) => {
  const slug = toCompetitorSlug(c.data.slug);
  return {
    slug,
    name: c.data.name,
    brandColor: c.data.brandColor,
    blurb: c.data.cardBlurb,
    startLabel: startLabelFor(c.data),
    overall: overallScore(c.data.scores),
    topDims: topThreeDims(c.data.scores),
    href: routes.review(slug),
  };
});

const recentGuides = guides.slice(0, 4).map((guide) => ({
  href: `${routes.guides()}${guide.slug}/`,
  title: guide.data.title,
  description: guide.data.description,
  updatedDate: guide.data.updatedDate,
}));
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  jsonLd={jsonLd}
  pageType="website"
>
  <Hero
    eyebrow="Independent review hub · Updated April 2026"
    title="The ad-spy research desk affiliate marketers can actually trust."
    sub="Hands-on ad spy tool reviews, rankings, head-to-heads, and research guides for affiliate marketers. Methodology, pricing dates, and page-level scope are all published plainly."
    primaryCta={{ href: "/ad-spy-tools/", label: "Browse ad spy tools" }}
    secondaryCta={{ href: routes.guides(), label: "Read the guides" }}
    withStats={true}
  />

  <section class="container-max" style="padding: 3rem 1.25rem;">
    <div class="intro-grid">
      <div class="intro-prose">
        <p class="intro-lead">
          Affiliate marketers buy their tools differently than brand marketers.
          You need specificity — tools that understand ClickBank creatives, that
          track days-running instead of impressions, that capture landing pages
          before they get pulled. Most review sites don't know the difference.
        </p>
        <p>
          AffiliateTools.co is built by operators for operators. The live
          editorial footprint today is ad spy tools plus the research workflows
          that make those tools useful: creative teardowns, landing page
          analysis, Meta Ad Library tactics, and affiliate-market fit. Every
          review admits where a competitor wins before it recommends anything.
          Every claim is dated. Every price cites the source.
        </p>
        <p>
          That matters because trust on a review site comes from scope
          discipline. We would rather be obviously complete in one category than
          pretend five categories are live before they are. Today that means <strong
            >deep ad-spy coverage</strong
          > and <strong>professional research guides</strong>, with broader
          affiliate software categories still clearly marked as future coverage.
        </p>
      </div>
      <aside class="intro-aside card">
        <h3
          class="label-mono"
          style="margin: 0 0 0.75rem; color: var(--color-gold); letter-spacing: 0.14em;"
        >
          Quick picks
        </h3>
        <ul class="quick-picks">
          <li>
            <strong>Best overall for Meta affiliates:</strong>
            <a href="/ad-spy-tools/adrecon-review/">AdRecon</a>
          </li>
          <li>
            <strong>Best for Boolean-search power users:</strong>
            <a href="/ad-spy-tools/adspy-review/">AdSpy</a>
          </li>
          <li>
            <strong>Best free tier:</strong>
            <a href="/ad-spy-tools/bigspy-review/">BigSpy</a>
          </li>
          <li>
            <strong>Best for TikTok:</strong>
            <a href="/ad-spy-tools/pipiads-review/">PiPiADS</a>
          </li>
          <li>
            <strong>Best for dropshipping:</strong>
            <a href="/ad-spy-tools/minea-review/">Minea</a>
          </li>
          <li>
            <strong>Best for agencies:</strong>
            <a href="/ad-spy-tools/foreplay-review/">Foreplay</a>
          </li>
        </ul>
      </aside>
    </div>
  </section>

  <section class="container-max" style="padding: 2rem 1.25rem 3rem;">
    <div class="section-header">
      <h2>Coverage today</h2>
      <p class="muted">
        What is fully published now, and what is deliberately still marked as
        upcoming.
      </p>
    </div>
    <div class="cat-grid">
      {
        liveCoverage.map((item) => (
          <a class="card cat-card cat-live" href={item.href}>
            <div class="cat-icon">{item.icon}</div>
            <div>
              <h3>{item.title}</h3>
              <p>{item.body}</p>
              <span class="chip chip-gold">{item.badge}</span>
            </div>
          </a>
        ))
      }
      {
        onDeckCoverage.map((item) => (
          <div class="card cat-card cat-soon">
            <div class="cat-icon">{item.icon}</div>
            <div>
              <h3>{item.title}</h3>
              <p>{item.body}</p>
              <span class="chip">On deck</span>
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <section class="container-max" style="padding: 3rem 1.5rem 4rem;">
    <div class="section-heading">
      <h2>Featured reviews</h2>
      <p>
        All 7 ad spy tools we cover — each reviewed hands-on across 8 weighted
        dimensions.
      </p>
    </div>
    <div class="review-grid">
      {
        competitorCards.map((card) => (
          <a class="rev" href={card.href} style={`--rev-brand: ${card.brandColor};`}>
            <div class="rev__topline">
              <span class="rev__rank label-mono">Review</span>
              <span class="rev__price">{card.startLabel}</span>
            </div>
            <div class="rev__hero">
              <div class="rev__logo-wrap">
                <ToolLogo
                  slug={card.slug}
                  size="lg"
                  surface="none"
                  mode="mark"
                  showName
                />
              </div>
              <div class="rev__score-wrap">
                <span class="rev__score-label label-mono">Score</span>
                <Rating value={card.overall} size="md" />
              </div>
            </div>
            <h3 class="rev__name">{card.name}</h3>
            <p class="rev__blurb">{card.blurb}</p>
            <ul class="rev__dims">
              {card.topDims.map(([k, v]) => (
                <li class="rev__dim">
                  <span class="rev__dim-topline">
                    <span class="rev__dim-name">{DIM_NAMES[k]}</span>
                    <span class="rev__dim-val">{v.toFixed(1)}</span>
                  </span>
                  <span class="rev__dim-track" aria-hidden="true">
                    <span
                      class="rev__dim-fill"
                      style={`width: ${v * 10}%;`}
                    />
                  </span>
                </li>
              ))}
            </ul>
            <span class="rev__cta">
              Read full review
              <svg
                width="14"
                height="14"
                viewBox="0 0 14 14"
                fill="none"
                aria-hidden="true"
              >
                <path
                  d="M3 7h8m0 0L7 3m4 4l-4 4"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
            </span>
          </a>
        ))
      }
    </div>
  </section>

  <ScoringMethodology />

  <section class="container-max" style="padding: 2rem 1.25rem 3rem;">
    <div class="section-header">
      <h2>Popular head-to-heads</h2>
      <p class="muted">
        Direct tool-vs-tool breakdowns for the matchups readers ask about most.
      </p>
    </div>
    <div class="versus-grid">
      {
        featuredComparisons.map((entry) => (
          <a class="card versus-card" href={entry.href}>
            <span class="label-mono" style="color: var(--color-gold);">
              Head-to-head
            </span>
            <h3 style="font-size: 1.125rem; margin: 0.35rem 0;">
              {entry.title}
            </h3>
            <span class="arrow">Compare →</span>
          </a>
        ))
      }
    </div>
  </section>

  <section class="container-max" style="padding: 2rem 1.25rem 3rem;">
    <div class="section-header">
      <h2>Best of</h2>
      <p class="muted">Ranked listicles across the most-asked queries.</p>
    </div>
    <div class="listicle-grid">
      {
        flagshipListicles.map((l) => (
          <a class="card listicle-card" href={routes.listicle(l.slug)}>
            <h3>{l.title}</h3>
            <p class="muted" style="font-size: 0.95rem;">
              {l.blurb}
            </p>
            <span class="arrow">Read ranking →</span>
          </a>
        ))
      }
    </div>
  </section>

  <section class="container-max" style="padding: 0 1.25rem 3rem;">
    <div class="section-header">
      <h2>Recent guides</h2>
      <p class="muted">
        Workflow playbooks for Meta research, LP teardowns, and affiliate
        decision-making.
      </p>
    </div>
    <div class="guides-preview-grid">
      {
        recentGuides.map((guide) => (
          <a class="card guides-preview-card" href={guide.href}>
            <span class="label-mono guides-preview-card__eyebrow">
              Guide · Updated {guide.updatedDate}
            </span>
            <h3>{guide.title}</h3>
            <p>{guide.description}</p>
            <span class="guides-preview-card__arrow">Read guide →</span>
          </a>
        ))
      }
    </div>
  </section>

  <section class="container-max" style="padding: 2rem 1.25rem 3rem;">
    <div class="section-header">
      <h2>Why AffiliateTools.co</h2>
    </div>
    <div class="why-grid">
      <div class="card why-card">
        <div class="why-icon">◆</div>
        <h3>Affiliate-native</h3>
        <p>
          Written for working affiliate marketers. We know the difference
          between a ClickBank creative and an e-commerce one.
        </p>
      </div>
      <div class="card why-card">
        <div class="why-icon">◇</div>
        <h3>Scope-first honesty</h3>
        <p>
          We publish each tool's limitations clearly, from platform gaps to
          pricing tradeoffs. If another tool wins for your use case, we say so.
        </p>
      </div>
      <div class="card why-card">
        <div class="why-icon">⬡</div>
        <h3>No paid placements</h3>
        <p>
          No tool paid to be included or ranked. We cite competitor marketing
          claims as claims — not facts — and date every price.
        </p>
      </div>
    </div>
  </section>

  <FAQ items={faqs} heading="Frequently asked questions" />
</BaseLayout>

<style>
  .intro-grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: 3rem;
    align-items: start;
  }
  @media (max-width: 900px) {
    .intro-grid {
      grid-template-columns: 1fr;
    }
  }
  .intro-lead {
    font-size: 1.25rem;
    color: var(--color-type);
    line-height: 1.55;
  }
  .intro-aside {
    padding: 1.5rem;
  }
  .quick-picks {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .quick-picks li {
    padding: 0.5rem 0;
    border-bottom: 1px solid var(--color-line);
    font-size: 0.95rem;
  }
  .quick-picks li:last-child {
    border-bottom: 0;
  }

  .section-header {
    margin-bottom: 1.5rem;
  }
  .section-header h2 {
    margin-top: 0;
  }
  .muted {
    color: var(--color-ink-mute);
  }

  .cat-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1rem;
  }
  .cat-card {
    padding: 1.5rem;
    display: flex;
    gap: 1rem;
    text-decoration: none;
    color: inherit;
    transition: transform 0.15s ease;
  }
  .cat-card:hover {
    transform: translateY(-2px);
  }
  .cat-card.cat-live {
    border-color: color-mix(in oklch, var(--color-gold) 35%, var(--color-line));
  }
  .cat-card.cat-soon {
    opacity: 0.72;
    cursor: default;
  }
  .cat-card h3 {
    margin: 0 0 0.4rem;
    font-size: 1.125rem;
  }
  .cat-card p {
    margin: 0 0 0.5rem;
    font-size: 0.93rem;
    color: var(--color-ink-mute);
  }
  .cat-icon {
    font-size: 1.75rem;
    color: var(--color-gold);
    line-height: 1;
    flex: 0 0 auto;
  }

  /* ===== Dark review cards (Linear/Stripe dashboard style) ===== */
  .review-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1rem;
  }
  .rev {
    display: flex;
    flex-direction: column;
    padding: 1.5rem 1.5rem 1.25rem;
    background:
      radial-gradient(
        ellipse 80% 50% at 50% 0%,
        color-mix(in srgb, var(--rev-brand) 20%, transparent),
        transparent 70%
      ),
      linear-gradient(180deg, #0f1724 0%, #0a0f1a 100%);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 14px;
    color: #ffffff;
    text-decoration: none;
    position: relative;
    overflow: hidden;
    transition:
      transform 0.22s cubic-bezier(0.2, 0.8, 0.2, 1),
      box-shadow 0.22s ease,
      border-color 0.22s ease;
    box-shadow: 0 1px 2px rgba(11, 20, 32, 0.05);
  }
  .rev::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 0;
    border-radius: 14px;
    pointer-events: none;
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.06) 0%,
      transparent 30%
    );
    mix-blend-mode: overlay;
  }
  .rev > * {
    position: relative;
    z-index: 1;
  }
  .rev:hover {
    transform: translateY(-3px);
    border-color: rgba(184, 199, 227, 0.22);
    box-shadow:
      0 24px 48px -20px rgba(10, 15, 26, 0.55),
      0 0 0 1px rgba(120, 150, 210, 0.12);
    text-decoration: none;
  }

  .rev__topline {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
    gap: 0.75rem;
  }
  .rev__rank {
    color: rgba(255, 255, 255, 0.42);
    letter-spacing: 0.14em;
    font-weight: 600;
    font-size: 0.65rem;
    text-transform: uppercase;
    font-family: var(--font-mono);
  }
  .rev__price {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: rgba(255, 255, 255, 0.72);
    letter-spacing: -0.005em;
    padding: 0.18rem 0.55rem;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    background: rgba(255, 255, 255, 0.04);
    white-space: nowrap;
  }

  .rev__hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 1rem;
    align-items: stretch;
    margin-bottom: 1rem;
  }
  .rev__logo-wrap {
    background:
      linear-gradient(
        135deg,
        color-mix(in srgb, var(--rev-brand) 10%, #ffffff) 0%,
        color-mix(in srgb, var(--rev-brand) 4%, #f5f7fb) 100%
      );
    border-radius: 18px;
    padding: 1rem 1.05rem;
    display: flex;
    align-items: center;
    justify-content: flex-start;
    min-height: 88px;
    border: 1px solid color-mix(in srgb, var(--rev-brand) 18%, rgba(255, 255, 255, 0.08));
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.55),
      0 18px 32px -28px rgba(6, 10, 18, 0.9);
  }
  .rev__logo-wrap :global(.tool-logo) {
    max-width: 100%;
  }
  .rev__logo-wrap :global(img),
  .rev__logo-wrap :global(svg) {
    max-height: 34px;
    max-width: 100%;
    width: auto;
  }
  .rev__score-wrap {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    justify-content: space-between;
    gap: 0.55rem;
  }
  .rev__score-label {
    color: rgba(255, 255, 255, 0.48);
  }
  .rev__score-wrap :global(.rating-pill) {
    min-width: 6.1rem;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.85), rgba(255, 255, 255, 0.24)),
      color-mix(in srgb, var(--rev-brand) 13%, #eef2f7);
    border-color: color-mix(in srgb, var(--rev-brand) 20%, rgba(255, 255, 255, 0.16));
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.68),
      0 20px 32px -26px rgba(6, 10, 18, 0.92);
  }
  .rev__score-wrap :global(.rating-label) {

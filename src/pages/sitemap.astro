---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Hero from "@/components/Hero.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import { breadcrumbList } from "@/lib/schema";
import { getCollection } from "astro:content";
import { routes, COMPETITOR_SLUGS, COMPETITOR_NAMES } from "@/lib/constants";

const title = "Site Map — AffiliateTools.co";
const description =
  "Full HTML site map of AffiliateTools.co — every page on the site organized by section.";
const canonical = "/sitemap/";
const jsonLd = [
  breadcrumbList([
    { name: "Home", path: "/" },
    { name: "Site Map", path: "/sitemap/" },
  ]),
];

const versusEntries = await getCollection("versus", ({ data }) => !data.draft);
const listicles = await getCollection("listicles", ({ data }) => !data.draft);
const intents = await getCollection("intent", ({ data }) => !data.draft);
const guides = await getCollection("guides", ({ data }) => !data.draft);

const adreconVersus = versusEntries.filter((entry) =>
  entry.slug.startsWith("adrecon-vs-"),
);
const competitorVersus = versusEntries.filter(
  (entry) => !entry.slug.startsWith("adrecon-vs-"),
);

function isCompetitorSlug(
  slug: string,
): slug is (typeof COMPETITOR_SLUGS)[number] {
  return (COMPETITOR_SLUGS as readonly string[]).includes(slug);
}
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  jsonLd={jsonLd}
>
  <section class="container-max" style="padding: 1.5rem 1.5rem 0;">
    <Breadcrumb items={[{ name: "Home", href: "/" }, { name: "Site Map" }]} />
  </section>

  <Hero
    eyebrow="Navigation"
    title="Site map"
    sub="Every page on AffiliateTools.co, organized by section."
    variant="compact"
  />

  <article class="container-max" style="padding: 2rem 1.5rem 4rem;">
    <div class="sitemap-grid">
      <section class="sitemap-col">
        <h2>Core</h2>
        <ul>
          <li><a href="/">Home</a></li>
          <li><a href="/about/">About</a></li>
          <li><a href={routes.guides()}>Guides</a></li>
          <li><a href="/methodology/">Methodology</a></li>
          <li><a href="/disclosure/">Editorial standards</a></li>
          <li><a href="/contact/">Contact</a></li>
        </ul>

        <h2 style="margin-top: 2.5rem;">Ad spy tools</h2>
        <ul>
          <li><a href={routes.hub()}>Category hub</a></li>
        </ul>
      </section>

      <section class="sitemap-col">
        <h2>Reviews</h2>
        <ul>
          {
            COMPETITOR_SLUGS.map((slug) => (
              <li>
                <a href={routes.review(slug)}>
                  {COMPETITOR_NAMES[slug]} review
                </a>
              </li>
            ))
          }
        </ul>
      </section>

      <section class="sitemap-col">
        <h2>Head-to-head comparisons</h2>
        <ul>
          {
            adreconVersus.map((entry) => {
              const slug = entry.data.competitorSlug;
              if (!isCompetitorSlug(slug)) return null;

              return (
                <li>
                  <a href={`/ad-spy-tools/${entry.slug}/`}>
                    AdRecon vs {COMPETITOR_NAMES[slug]}
                  </a>
                </li>
              );
            })
          }
        </ul>

        <h2 style="margin-top: 2.5rem;">Competitor pairings</h2>
        <ul>
          {
            competitorVersus.map((entry) => (
              <li>
                <a href={`/ad-spy-tools/${entry.slug}/`}>{entry.data.title}</a>
              </li>
            ))
          }
        </ul>
      </section>

      <section class="sitemap-col">
        <h2>Rankings</h2>
        <ul>
          {
            listicles.map((entry) => (
              <li>
                <a href={`/ad-spy-tools/${entry.slug}/`}>{entry.data.title}</a>
              </li>
            ))
          }
        </ul>

        <h2 style="margin-top: 2.5rem;">Buyer questions</h2>
        <ul>
          {
            intents.map((entry) => (
              <li>
                <a href={`/ad-spy-tools/${entry.slug}/`}>{entry.data.title}</a>
              </li>
            ))
          }
        </ul>
      </section>

      <section class="sitemap-col">
        <h2>Guides</h2>
        <ul>
          <li><a href={routes.guides()}>All guides</a></li>
          {
            guides.map((entry) => (
              <li>
                <a href={`/guides/${entry.slug}/`}>{entry.data.title}</a>
              </li>
            ))
          }
        </ul>
      </section>

      <section class="sitemap-col">
        <h2>Legal</h2>
        <ul>
          <li><a href={routes.privacy()}>Privacy Policy</a></li>
          <li><a href={routes.terms()}>Terms of Service</a></li>
          <li><a href={routes.cookies()}>Cookie Policy</a></li>
          <li><a href={routes.disclosure()}>Editorial standards</a></li>
        </ul>

        <h2 style="margin-top: 2.5rem;">Machine-readable</h2>
        <ul>
          <li><a href="/sitemap-index.xml">XML sitemap index</a></li>
          <li><a href="/robots.txt">robots.txt</a></li>
          <li><a href={routes.rss()}>RSS feed</a></li>
        </ul>
      </section>
    </div>
  </article>
</BaseLayout>

<style>
  .sitemap-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }
  @media (min-width: 720px) {
    .sitemap-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 1080px) {
    .sitemap-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }
  @media (min-width: 1400px) {
    .sitemap-grid {
      grid-template-columns: repeat(5, 1fr);
    }
  }
  .sitemap-col h2 {
    font-size: 0.92rem;
    font-weight: 700;
    margin-top: 0;
    margin-bottom: 0.85rem;
    color: var(--color-type);
    letter-spacing: -0.01em;
  }
  .sitemap-col ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }
  .sitemap-col li {
    margin: 0;
  }
  .sitemap-col a {
    color: var(--color-type-dim);
    font-size: 0.9rem;
    text-decoration: none;
  }
  .sitemap-col a:hover {
    color: var(--color-accent);
    text-decoration: none;
  }
</style>

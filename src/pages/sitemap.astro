---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/Hero.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import { getCollection } from 'astro:content';
import { breadcrumbList } from '@/lib/schema';
import { routes, COMPETITOR_SLUGS, VERSUS_SLUGS, COMPETITOR_NAMES } from '@/lib/constants';

const title = 'Site Map — AffiliateTools.co';
const description = 'Full HTML site map of AffiliateTools.co — every review, comparison, ranking, buyer guide, and educational resource organized by section.';
const canonical = '/sitemap/';
const jsonLd = [
  breadcrumbList([
    { name: 'Home', path: '/' },
    { name: 'Site Map', path: '/sitemap/' },
  ]),
];

const listicles = (await getCollection('listicles', ({ data }) => !data.draft))
  .sort((a, b) => a.data.title.localeCompare(b.data.title));

const intents = (await getCollection('intent', ({ data }) => !data.draft))
  .sort((a, b) => a.data.title.localeCompare(b.data.title));

const guides = (await getCollection('guides', ({ data }) => !data.draft))
  .sort((a, b) => a.data.title.localeCompare(b.data.title));

const allVersus = (await getCollection('versus', ({ data }) => !data.draft)).map((v) => v.slug);
const adreconVersus = allVersus.filter((s) => s.startsWith('adrecon-vs-'));
const competitorVersus = allVersus.filter((s) => !s.startsWith('adrecon-vs-'));

const prettifyVersus = (slug: string): string => {
  const parts = slug.split('-vs-');
  const pretty = (p: string) =>
    COMPETITOR_NAMES[p as keyof typeof COMPETITOR_NAMES] ?? p.charAt(0).toUpperCase() + p.slice(1);
  return `${pretty(parts[0] ?? '')} vs ${pretty(parts[1] ?? '')}`;
};
---

<BaseLayout title={title} description={description} canonical={canonical} jsonLd={jsonLd}>
  <section class="container-max" style="padding: 1.5rem 1.5rem 0;">
    <Breadcrumb items={[{ name: 'Home', href: '/' }, { name: 'Site Map' }]} />
  </section>

  <Hero
    eyebrow="Navigation"
    title="Site map"
    sub={`Every page on AffiliateTools.co — ${COMPETITOR_SLUGS.length} reviews, ${allVersus.length} head-to-heads, ${listicles.length} rankings, ${intents.length} buyer-intent pages, and ${guides.length} guides.`}
    variant="compact"
  />

  <article class="container-max" style="padding: 2rem 1.5rem 4rem;">
    <div class="sitemap-grid">
      <section class="sitemap-col">
        <h2>Core</h2>
        <ul>
          <li><a href="/">Home</a></li>
          <li><a href="/about/">About</a></li>
          <li><a href="/methodology/">Methodology</a></li>
          <li><a href="/disclosure/">Editorial disclosure</a></li>
          <li><a href="/contact/">Contact</a></li>
        </ul>

        <h2 style="margin-top: 2.5rem;">Ad spy tools</h2>
        <ul>
          <li><a href={routes.hub()}>Category hub</a></li>
        </ul>

        <h2 style="margin-top: 2.5rem;">Reviews</h2>
        <ul>
          {COMPETITOR_SLUGS.map((slug) => (
            <li><a href={routes.review(slug)}>{COMPETITOR_NAMES[slug]} review</a></li>
          ))}
        </ul>

        <h2 style="margin-top: 2.5rem;">Legal</h2>
        <ul>
          <li><a href="/privacy/">Privacy Policy</a></li>
          <li><a href="/terms/">Terms of Service</a></li>
          <li><a href="/cookies/">Cookie Policy</a></li>
          <li><a href="/disclosure/">Editorial disclosure</a></li>
        </ul>

        <h2 style="margin-top: 2.5rem;">Machine-readable</h2>
        <ul>
          <li><a href="/sitemap-index.xml">XML sitemap index</a></li>
          <li><a href="/robots.txt">robots.txt</a></li>
          <li><a href="/rss.xml">RSS feed</a></li>
        </ul>
      </section>

      <section class="sitemap-col">
        <h2>AdRecon head-to-heads</h2>
        <ul>
          {VERSUS_SLUGS.map((slug) => (
            <li><a href={routes.versus(slug)}>AdRecon vs {COMPETITOR_NAMES[slug]}</a></li>
          ))}
        </ul>

        <h2 style="margin-top: 2.5rem;">Competitor head-to-heads</h2>
        <ul>
          {competitorVersus.map((slug) => (
            <li><a href={`/ad-spy-tools/${slug}/`}>{prettifyVersus(slug)}</a></li>
          ))}
        </ul>
      </section>

      <section class="sitemap-col">
        <h2>Rankings</h2>
        <ul>
          {listicles.map((l) => (
            <li><a href={`/ad-spy-tools/${l.slug}/`}>{l.data.title}</a></li>
          ))}
        </ul>
      </section>

      <section class="sitemap-col">
        <h2>Buyer-intent pages</h2>
        <ul>
          {intents.map((i) => (
            <li><a href={`/ad-spy-tools/${i.slug}/`}>{i.data.title}</a></li>
          ))}
        </ul>

        <h2 style="margin-top: 2.5rem;">Guides</h2>
        <ul>
          <li><a href="/guides/">All guides</a></li>
          {guides.map((g) => (
            <li><a href={`/guides/${g.slug}/`}>{g.data.title}</a></li>
          ))}
        </ul>
      </section>
    </div>
  </article>
</BaseLayout>

<style>
  .sitemap-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }
  @media (min-width: 720px) { .sitemap-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1080px) { .sitemap-grid { grid-template-columns: repeat(4, 1fr); } }
  .sitemap-col h2 {
    font-size: 0.92rem;
    font-weight: 700;
    margin-top: 0;
    margin-bottom: 0.85rem;
    color: var(--color-type);
    letter-spacing: -0.01em;
  }
  .sitemap-col ul { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.55rem; }
  .sitemap-col li { margin: 0; }
  .sitemap-col a { color: var(--color-type-dim); font-size: 0.9rem; text-decoration: none; line-height: 1.4; }
  .sitemap-col a:hover { color: var(--color-accent); text-decoration: none; }
</style>

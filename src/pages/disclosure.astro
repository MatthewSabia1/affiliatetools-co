---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Hero from "@/components/Hero.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import { breadcrumbList } from "@/lib/schema";

const title = "Editorial Standards — AffiliateTools.co";
const description =
  "The editorial standards, corrections policy, and review guardrails behind AffiliateTools.co.";
const canonical = "/disclosure/";
const jsonLd = [
  breadcrumbList([
    { name: "Home", path: "/" },
    { name: "Editorial Standards", path: "/disclosure/" },
  ]),
];
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  jsonLd={jsonLd}
>
  <section class="container-max" style="padding: 1.5rem 1.5rem 0;">
    <Breadcrumb
      items={[{ name: "Home", href: "/" }, { name: "Editorial Standards" }]}
    />
  </section>

  <Hero
    eyebrow="Editorial"
    title="Our editorial standards"
    sub="How reviews, rankings, corrections, and tradeoff calls are handled across the site."
    variant="compact"
  />

  <article class="container-prose" style="padding: 2rem 1.25rem 4rem;">
    <div class="prose">
      <h2>What this page is for</h2>
      <p>
        This page documents the standards behind AffiliateTools.co: how we keep
        reviews specific, how rankings are decided, what we do not allow
        commercially, and how factual corrections are handled.
      </p>

      <h2>How we keep reviews fair</h2>
      <p>
        Five structural rules guide every review, versus page, listicle, and
        buyer guide:
      </p>
      <ol>
        <li>
          <strong>Strongest case first.</strong> Reviews lead with the clearest reasons
          a buyer might choose the tool being evaluated, not with generic praise or
          defensive caveats.
        </li>
        <li>
          <strong>Tradeoffs must be visible.</strong> Comparison tables and verdict
          sections are written to show where each option wins, loses, or narrows the
          field.
        </li>
        <li>
          <strong>Scope before hype.</strong> If a tool only makes sense for one buyer
          type or platform, we say that directly instead of stretching it into a broader
          recommendation.
        </li>
        <li>
          <strong>Buyer intent drives rankings.</strong> Rankings change when the
          use case changes. Free-tier pages, TikTok pages, Meta pages, and dropshipping
          pages are not forced into the same winner.
        </li>
        <li>
          <strong>Competitor claims cited as claims.</strong> "AdSpy claims 200M+
          ads" — never "AdSpy has 200M+ ads." Competitor marketing numbers appear
          in quotes with attribution, never as facts.
        </li>
      </ol>

      <h2>What we don't do</h2>
      <ul>
        <li>We do not accept paid rankings or sponsored reviews.</li>
        <li>
          We do not include affiliate links to competitor tools (as of April
          2026). If we add any in the future, they will carry visible labels and <code
            >rel="sponsored"</code
          >.
        </li>
        <li>
          We do not fabricate user testimonials, reviews, or star ratings.
        </li>
        <li>
          We do not silently edit reviews when tools complain. Corrections are
          dated.
        </li>
        <li>
          We do not use undisclosed AI-generated "reviews" dressed up as human
          opinion. Reviews are written from hands-on testing.
        </li>
      </ul>

      <h2>How to tell if we've failed</h2>
      <p>
        If you read multiple reviews and come away feeling that every page is
        trying to force the same answer, we've written badly and should know.
        Email us at <a href="mailto:hello@affiliatetools.co"
          >hello@affiliatetools.co</a
        > with the specific page and what felt off. We take bias complaints seriously
        and publish corrections.
      </p>

      <h2>Factual corrections</h2>
      <p>
        Prices, feature sets, and policies of competitor tools change. We audit
        quarterly but readers spot errors faster than we do. If you notice a
        factual error, email us with the page URL, the error, and (ideally) a
        source. We publish corrections within 72 hours and never silently edit.
      </p>

      <h2>What these standards cover</h2>
      <p>
        These standards apply to every piece of content on AffiliateTools.co —
        reviews, versus pages, listicles, guides, and comparison tables. Every
        page links back to this document and to our <a href="/methodology/"
          >methodology</a
        >.
      </p>

      <h2>Contact</h2>
      <p>
        Editorial concerns → <a href="mailto:hello@affiliatetools.co"
          >hello@affiliatetools.co</a
        >. Subject line: <code>EDITORIAL</code>.
      </p>
    </div>
  </article>
</BaseLayout>

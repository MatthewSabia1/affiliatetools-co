---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/Hero.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import { breadcrumbList } from '@/lib/schema';

const title = 'Editorial Disclosure — AffiliateTools.co';
const description = 'AffiliateTools.co uses affiliate links on some pages. Here is how we disclose them, how we handle pay-to-rank requests, and how we score the tools we review.';
const canonical = '/disclosure/';
const jsonLd = [
  breadcrumbList([
    { name: 'Home', path: '/' },
    { name: 'Editorial Disclosure', path: '/disclosure/' },
  ]),
];
---

<BaseLayout title={title} description={description} canonical={canonical} jsonLd={jsonLd}>
  <section class="container-max" style="padding: 1.5rem 1.5rem 0;">
    <Breadcrumb items={[{ name: 'Home', href: '/' }, { name: 'Editorial Disclosure' }]} />
  </section>

  <Hero
    eyebrow="Editorial"
    title="Our editorial disclosure"
    sub="How we handle affiliate links, pay-to-rank requests, and factual corrections."
    variant="compact"
  />

  <article class="container-prose" style="padding: 2rem 1.25rem 4rem;">
    <div class="prose">
      <h2>Affiliate links</h2>
      <p>Some links on AffiliateTools.co are affiliate links. If you sign up for a product through one of those links, we may earn a commission at no additional cost to you. This is standard for independent review sites and is how we fund ongoing coverage, pricing audits, and editorial work.</p>
      <p>Every affiliate link on this site:</p>
      <ul>
        <li>Carries <code>rel="sponsored"</code> on the anchor tag, so browsers and search crawlers handle it correctly.</li>
        <li>Appears alongside editorial content that has not been paid for by the linked vendor.</li>
        <li>Can be declined at any time — the tool's website is linked separately, without the affiliate parameter, on the same page where available.</li>
      </ul>

      <h2>Pay-to-rank policy</h2>
      <p>No tool on this site can pay to be included, to be moved up a listicle, or to have a negative verdict softened. Ranking position comes from the scoring rubric documented on the <a href="/methodology/">methodology page</a>, not from commercial relationships.</p>
      <p>If you are a tool vendor and want to suggest additions or corrections to a review, email us — we're happy to review factual input, but editorial decisions stay on the editorial side.</p>

      <h2>What we don't do</h2>
      <ul>
        <li>We do not accept paid rankings or sponsored "best of" slots.</li>
        <li>We do not hide affiliate links. Every affiliate link is labeled with <code>rel="sponsored"</code>.</li>
        <li>We do not fabricate user testimonials, reviews, or star ratings.</li>
        <li>We do not silently edit reviews when tools complain. Corrections are dated and visible.</li>
        <li>We do not cover tools we haven't actually used. Every review is based on hands-on testing, not marketing copy.</li>
      </ul>

      <h2>How we score tools</h2>
      <p>Every tool is scored on the same 8-dimension rubric: coverage, data freshness, price, UX, landing-page tools, offer intelligence, affiliate focus, and search depth. Each dimension gets a 1–10 score after firsthand testing. Weightings vary by listicle intent — our <a href="/methodology/">methodology page</a> documents the weights used per ranking.</p>

      <h2>Factual corrections</h2>
      <p>Prices, feature sets, and policies of tools we review change. We audit quarterly but readers spot errors faster than we do. If you notice a factual error, email us with the page URL, the error, and (ideally) a source. We publish corrections within 72 hours and never silently edit.</p>

      <h2>What this disclosure covers</h2>
      <p>This disclosure applies to every piece of content on AffiliateTools.co — reviews, versus pages, listicles, guides, and comparison tables. Every page links back to this document and to our <a href="/methodology/">methodology</a>.</p>

      <h2>Contact</h2>
      <p>Editorial concerns → <a href="mailto:hello@affiliatetools.co">hello@affiliatetools.co</a>. Subject line: <code>EDITORIAL</code>.</p>
    </div>
  </article>
</BaseLayout>
